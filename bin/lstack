#!/usr/bin/env bash
# lstack — personal Claude Code environment CLI

set -euo pipefail

CLAUDE_DIR="${HOME}/.claude"
VERSION="1.0.0"

usage() {
    cat <<EOF
lstack ${VERSION} — Claude Code personal environment

Commands:
  init              Scaffold .claude/ in current project directory
  settings          Regenerate settings.json for the current OS
  doctor            Diagnose installation health
  onboard           Interactive first-run setup
  memory            Open project or global MEMORY.md in \$EDITOR
  memory stats      Show persistent DB stats
  memory list           List all observations (current project + global)
  memory list --global  List only global observations
  memory list --tag X   Filter by tag
  memory prune [--days N]  Delete observations older than N days (default 90)
  search [query]    Search persistent memory for [query]
  logs              Tail tool-calls.log with color
  status            Show hook health, memory sizes, session/compaction timestamps
  clean             Prune logs >30 days; remove loop/reads state for dead PIDs
  dashboard         Live display of parallel agent worktrees
  upgrade           Pull latest lstack from git origin
  publish           Package lstack for open-source sharing
  forget [query]    Delete matching observations from persistent memory
  edit [query]      Search and interactively edit an observation
  analytics         Show memory analytics — observations per week, top tags, scope breakdown
  mcp               Start lstack MCP server (stdio transport)
  memory embed-all  Backfill semantic embeddings for all observations
  sync              Sync memory to/from a private git repo (cross-device)
  help              Show this message
EOF
}

cmd_init() {
    local project_dir
    project_dir="$(pwd)"

    if [ -d "${project_dir}/.claude" ]; then
        echo "Error: .claude/ already exists in ${project_dir}"
        exit 1
    fi

    echo "Initializing lstack project in ${project_dir}..."

    # Auto-detect project context
    echo "Scanning project..."

    detected_stack=""
    detected_test=""
    detected_dev=""
    detected_build=""
    detected_lint=""
    detected_name="$(basename "$(pwd)")"

    # Node / TypeScript
    if [ -f "package.json" ]; then
        pkg_name="$("${PYTHON}" -c "
import json
try:
  d=json.load(open('package.json'))
  print(d.get('name',''))
except: print('')
" 2>/dev/null)"
        [ -n "${pkg_name}" ] && detected_name="${pkg_name}"

        detected_test="$("${PYTHON}" -c "
import json
try:
  s=json.load(open('package.json')).get('scripts',{})
  for k in ['test','jest','vitest']:
      if k in s: print(f'npm test'); break
  else: print('')
except: print('')
" 2>/dev/null)"
        detected_dev="$("${PYTHON}" -c "
import json
try:
  s=json.load(open('package.json')).get('scripts',{})
  for k in ['dev','start','serve']:
      if k in s: print(f'npm run {k}'); break
except: print('')
" 2>/dev/null)"
        detected_build="$("${PYTHON}" -c "
import json
try:
  s=json.load(open('package.json')).get('scripts',{})
  if 'build' in s: print('npm run build')
except: print('')
" 2>/dev/null)"

        if [ -f "tsconfig.json" ]; then
            detected_stack="TypeScript/Node"
        else
            detected_stack="JavaScript/Node"
        fi
        if [ -f "next.config.js" ] || [ -f "next.config.ts" ]; then
            detected_stack="TypeScript/Next.js"
        elif grep -q '"react"' package.json 2>/dev/null; then
            detected_stack="TypeScript/React"
        fi
        if [ -f ".eslintrc.json" ] || [ -f ".eslintrc.js" ] || [ -f "eslint.config.js" ]; then
            detected_lint="npm run lint"
        fi
    fi

    # Python
    if [ -f "pyproject.toml" ] || [ -f "setup.py" ] || [ -f "requirements.txt" ]; then
        detected_stack="Python"
        if [ -f "pyproject.toml" ]; then
            detected_test="pytest"
            detected_lint="ruff check ."
        fi
        if grep -q "fastapi" requirements.txt 2>/dev/null || \
           grep -q "fastapi" pyproject.toml 2>/dev/null; then
            detected_stack="Python/FastAPI"
            detected_dev="uvicorn main:app --reload"
        fi
    fi

    # Go
    if [ -f "go.mod" ]; then
        detected_stack="Go"
        detected_test="go test ./..."
        detected_build="go build ./..."
        detected_lint="golangci-lint run"
        detected_name="$(head -1 go.mod | awk '{print $2}' | xargs basename 2>/dev/null || echo "${detected_name}")"
    fi

    # Rust
    if [ -f "Cargo.toml" ]; then
        detected_stack="Rust"
        detected_test="cargo test"
        detected_build="cargo build --release"
        detected_lint="cargo clippy"
    fi

    printf '\nDetected project info (press Enter to accept, or type to override):\n\n'

    printf "Project name [${detected_name}]: "
    read -r project_name
    project_name="${project_name:-${detected_name}}"

    printf "Tech stack [${detected_stack:-unknown}]: "
    read -r project_stack
    project_stack="${project_stack:-${detected_stack}}"

    printf "Test command [${detected_test:-none}]: "
    read -r test_cmd
    test_cmd="${test_cmd:-${detected_test}}"

    printf "Dev command [${detected_dev:-none}]: "
    read -r dev_cmd
    dev_cmd="${dev_cmd:-${detected_dev}}"

    printf "Build command [${detected_build:-none}]: "
    read -r build_cmd
    build_cmd="${build_cmd:-${detected_build}}"

    printf "Lint command [${detected_lint:-none}]: "
    read -r lint_cmd
    lint_cmd="${lint_cmd:-${detected_lint}}"

    printf "Purpose (one line): "
    read -r purpose

    # Create directories
    mkdir -p "${project_dir}/.claude/memory"
    mkdir -p "${project_dir}/.claude/logs"

    # Write project CLAUDE.md
    cat > "${project_dir}/.claude/CLAUDE.md" <<CLAUDEEOF
## Project
Name:    ${project_name}
Stack:   ${project_stack}
Purpose: ${purpose}

## Build & Test
dev:   ${dev_cmd}
build: ${build_cmd}
test:  ${test_cmd}
lint:  ${lint_cmd}

## Architecture
<!-- 2-3 sentences max: how is the code organized? -->

## Conventions
<!-- One rule per bullet. -->
- Follow existing patterns in the codebase before introducing new ones
- All new code must have tests

## Memory
See .claude/memory/MEMORY.md
CLAUDEEOF

    # Write project MEMORY.md
    cat > "${project_dir}/.claude/memory/MEMORY.md" <<MEMEOF
# ${project_name} — project memory index
# Keep lean. Claude updates this as context accumulates.

## Architecture
See architecture.md

## Debugging
See debugging.md

## Conventions
See conventions.md
MEMEOF

    # Write empty memory files
    printf '# Architecture\n<!-- Key architectural decisions and rationale -->\n' > "${project_dir}/.claude/memory/architecture.md"
    printf '# Debugging\n<!-- Known issues, root causes, reproduction steps -->\n' > "${project_dir}/.claude/memory/debugging.md"
    printf '# Conventions\n<!-- Project-specific coding conventions -->\n' > "${project_dir}/.claude/memory/conventions.md"

    # Add logs to .gitignore
    if [ -f "${project_dir}/.gitignore" ]; then
        if ! grep -q '\.claude/logs' "${project_dir}/.gitignore"; then
            printf '\n# Claude Code lstack logs\n.claude/logs/\n.claude/memory/handover.md\n' >> "${project_dir}/.gitignore"
        fi
    else
        printf '# Claude Code lstack logs\n.claude/logs/\n.claude/memory/handover.md\n' > "${project_dir}/.gitignore"
    fi

    echo ""
    echo "Done. Created:"
    echo "  .claude/CLAUDE.md"
    echo "  .claude/memory/MEMORY.md"
    echo "  .claude/memory/architecture.md"
    echo "  .claude/memory/debugging.md"
    echo "  .claude/memory/conventions.md"
    echo ""
    echo "Next: Edit .claude/CLAUDE.md to fill in Architecture and Conventions."

    # Regenerate global settings.json for current OS
    bash "${CLAUDE_DIR}/scripts/gen-settings.sh" > "${CLAUDE_DIR}/settings.json" 2>/dev/null && \
        echo "settings.json regenerated for current OS." || \
        echo "Warning: could not regenerate settings.json (run: lstack settings)"
}

cmd_memory() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true

    case "${subcmd}" in
        stats)
            source "${CLAUDE_DIR}/scripts/os.sh"
            "${PYTHON}" "${CLAUDE_DIR}/scripts/db.py" stats
            ;;
        prune)
            source "${CLAUDE_DIR}/scripts/os.sh"
            "${PYTHON}" "${CLAUDE_DIR}/scripts/db.py" prune "$@"
            ;;
        embed-all)
            source "${CLAUDE_DIR}/scripts/os.sh"
            "${PYTHON}" "${CLAUDE_DIR}/scripts/db.py" embed-all
            ;;
        list)
            source "${CLAUDE_DIR}/scripts/os.sh"
            "${PYTHON}" "${CLAUDE_DIR}/scripts/db.py" list "$@"
            ;;
        "")
            local editor="${EDITOR:-nano}"
            local target
            git_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
            if [ -n "${git_root}" ] && [ -f "${git_root}/.claude/memory/MEMORY.md" ]; then
                target="${git_root}/.claude/memory/MEMORY.md"
                echo "Opening project memory: ${target}"
            else
                target="${CLAUDE_DIR}/memory/MEMORY.md"
                echo "Opening global memory: ${target}"
            fi
            "${editor}" "${target}"
            ;;
        *)
            echo "Unknown memory subcommand: ${subcmd}"
            echo "Usage: lstack memory [stats|prune [--days N]|embed-all]"
            exit 1
            ;;
    esac
}

cmd_search() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    local query="$*"
    if [ -z "${query}" ]; then
        echo "Usage: lstack search [query]"
        exit 1
    fi

    results="$("${PYTHON}" "${CLAUDE_DIR}/scripts/db.py" search "${query}" --limit 5 2>/dev/null)"

    count="$(printf '%s' "${results}" | "${PYTHON}" -c "
import sys,json
try: print(len(json.load(sys.stdin)))
except: print(0)
" 2>/dev/null || echo "0")"

    if [ "${count}" -eq 0 ]; then
        echo "No results for '${query}'"
        exit 0
    fi

    printf '%s' "${results}" | "${PYTHON}" -c "
import sys,json
try:
    items=json.load(sys.stdin)
    for i,it in enumerate(items,1):
        content=it.get('content','')
        date=(it.get('created_at',''))[:10]
        tags=it.get('tags','')
        print(f'[{i}] {date}  {content}')
        if tags:
            print(f'     tags: {tags}')
except Exception as e:
    print(f'Error: {e}')
"
}

cmd_logs() {
    local log_file="${CLAUDE_DIR}/logs/tool-calls.log"

    if [ ! -f "${log_file}" ]; then
        echo "No tool-calls.log found. Start a Claude session to generate logs."
        exit 0
    fi

    # Tail with color: blocked=red, timestamps=dim
    tail -f "${log_file}" | awk '
    {
        line = $0
        if (line ~ /Blocked|blocked|BLOCKED|exit 2/) {
            printf "\033[31m%s\033[0m\n", line
        } else if (line ~ /^\[20[0-9][0-9]-/) {
            # Dim the ISO timestamp portion
            printf "\033[2m%s\033[0m\n", line
        } else {
            print line
        }
        fflush()
    }'
}

cmd_status() {
    echo "=== lstack status ==="
    echo ""

    # Hook health
    echo "--- Hooks ---"
    for hook in session-start pre-tool post-tool pre-compact stop; do
        f="${CLAUDE_DIR}/hooks/${hook}.sh"
        if [ -f "${f}" ]; then
            if [ -x "${f}" ]; then
                echo "  ✓ ${hook}.sh (executable)"
            else
                echo "  ✗ ${hook}.sh (NOT executable)"
            fi
        else
            echo "  ✗ ${hook}.sh (MISSING)"
        fi
    done

    echo ""
    echo "--- Memory files ---"
    for mf in MEMORY.md preferences.md patterns.md projects.md; do
        f="${CLAUDE_DIR}/memory/${mf}"
        if [ -f "${f}" ]; then
            size="$(wc -c < "${f}" 2>/dev/null | tr -d ' ')"
            echo "  ${mf}: ${size} bytes"
        else
            echo "  ${mf}: MISSING"
        fi
    done

    echo ""
    echo "--- Last session ---"
    session_log="${CLAUDE_DIR}/logs/sessions.log"
    if [ -f "${session_log}" ]; then
        tail -3 "${session_log}"
    else
        echo "  No sessions logged yet"
    fi

    echo ""
    echo "--- Last compaction ---"
    compact_log="${CLAUDE_DIR}/logs/compactions.log"
    if [ -f "${compact_log}" ]; then
        tail -1 "${compact_log}"
    else
        echo "  No compactions logged yet"
    fi

    echo ""
    echo "--- Loop state files ---"
    log_dir="${CLAUDE_DIR}/logs"
    if [ -d "${log_dir}" ]; then
        loop_count=0
        for _lf in "${log_dir}"/loop-*.json; do
            [ -f "${_lf}" ] && loop_count=$(( loop_count + 1 )) || true
        done
        echo "  Active loop state files: ${loop_count}"
        if [ "${loop_count}" -gt 0 ] 2>/dev/null; then
            bash "${CLAUDE_DIR}/scripts/loop-detector.sh" 2>/dev/null || true
        fi
    else
        echo "  Log directory not found"
    fi
}

cmd_clean() {
    local log_dir="${CLAUDE_DIR}/logs"
    echo "Cleaning lstack logs..."

    if [ ! -d "${log_dir}" ]; then
        echo "No log directory found."
        exit 0
    fi

    # Prune log files older than 30 days (excluding loop state files)
    old_count=0
    for f in "${log_dir}"/*.log; do
        [ -f "${f}" ] || continue
        if find "${f}" -mtime +30 -print 2>/dev/null | grep -q .; then
            rm -f "${f}"
            old_count=$(( old_count + 1 ))
        fi
    done
    echo "  Removed ${old_count} log file(s) older than 30 days"

    # Remove loop state files for dead PIDs
    dead_count=0
    for f in "${log_dir}"/loop-*.json; do
        [ -f "${f}" ] || continue
        pid="$(basename "${f}" | sed 's/loop-//;s/\.json//')"
        if ! kill -0 "${pid}" 2>/dev/null; then
            rm -f "${f}"
            dead_count=$(( dead_count + 1 ))
        fi
    done
    echo "  Removed ${dead_count} loop state file(s) for dead PIDs"

    # Remove reads state files for dead PIDs
    reads_count=0
    for f in "${log_dir}"/reads-*.json; do
        [ -f "${f}" ] || continue
        pid="$(basename "${f}" | sed 's/reads-//;s/\.json//')"
        if ! kill -0 "${pid}" 2>/dev/null; then
            rm -f "${f}"
            reads_count=$(( reads_count + 1 ))
        fi
    done
    echo "  Removed ${reads_count} reads state file(s) for dead PIDs"

    # Remove semantic loop state files for dead PIDs
    errloop_count=0
    for f in "${log_dir}"/errloop-*.json; do
        [ -f "${f}" ] || continue
        pid="$(basename "${f}" | sed 's/errloop-//;s/\.json//')"
        if ! kill -0 "${pid}" 2>/dev/null; then
            rm -f "${f}"
            errloop_count=$(( errloop_count + 1 ))
        fi
    done
    echo "  Removed ${errloop_count} semantic loop state file(s) for dead PIDs"

    # Prune persistent DB observations older than 90 days
    source "${CLAUDE_DIR}/scripts/os.sh"
    if [ -n "${PYTHON}" ]; then
        db_prune_out="$("${PYTHON}" "${CLAUDE_DIR}/scripts/db.py" prune --days 90 2>/dev/null || echo "  (db.py not available)")"
        echo "  ${db_prune_out}"
    fi

    echo "Done."
}

cmd_dashboard() {
    exec bash "${CLAUDE_DIR}/scripts/dashboard.sh"
}

cmd_upgrade() {
    local git_dir="${CLAUDE_DIR}/.git"
    local git_source="${CLAUDE_DIR}/.git-source"

    if [ ! -d "${git_dir}" ]; then
        cat <<EOF
lstack was not installed via git. Cannot auto-upgrade.
To enable upgrades: git init ~/.claude && git remote add origin [your-repo-url]
EOF
        exit 1
    fi

    if ! git -C "${CLAUDE_DIR}" remote get-url origin >/dev/null 2>&1; then
        echo "No 'origin' remote configured."
        echo "Add one with: git -C ~/.claude remote add origin [url]"
        exit 1
    fi

    # Write .git-source if not present
    if [ ! -f "${git_source}" ]; then
        git -C "${CLAUDE_DIR}" remote get-url origin > "${git_source}" 2>/dev/null || true
    fi

    git -C "${CLAUDE_DIR}" fetch origin

    local local_sha remote_sha
    local_sha="$(git -C "${CLAUDE_DIR}" rev-parse HEAD 2>/dev/null)"
    remote_sha="$(git -C "${CLAUDE_DIR}" rev-parse origin/main 2>/dev/null)"

    if [ "${local_sha}" = "${remote_sha}" ]; then
        echo "Already up to date."
        exit 0
    fi

    local local_short="${local_sha:0:7}"
    local remote_short="${remote_sha:0:7}"
    echo "Updating lstack: ${local_short} -> ${remote_short}"

    git -C "${CLAUDE_DIR}" pull --ff-only origin main

    echo "Updated. Changes:"
    git -C "${CLAUDE_DIR}" log --oneline "${local_sha}..${remote_sha}"
    echo ""
    echo "Restart Claude Code to apply changes."
}

cmd_publish() {
    local timestamp
    timestamp="$(date -u '+%Y%m%dT%H%M%S' 2>/dev/null || echo 'now')"
    local staging="/tmp/lstack-publish-${timestamp}"

    echo "Creating staging directory: ${staging}"
    mkdir -p "${staging}/skills" "${staging}/hooks" "${staging}/scripts" "${staging}/bin"

    # Explicit copies — no wildcards that could grab sensitive files
    [ -f "${CLAUDE_DIR}/CLAUDE.md" ] && cp "${CLAUDE_DIR}/CLAUDE.md" "${staging}/CLAUDE.md"

    for f in "${CLAUDE_DIR}/skills/"*.md; do
        [ -f "${f}" ] && cp "${f}" "${staging}/skills/"
    done
    for f in "${CLAUDE_DIR}/hooks/"*.sh; do
        [ -f "${f}" ] && cp "${f}" "${staging}/hooks/"
    done
    for f in "${CLAUDE_DIR}/scripts/"*.sh; do
        [ -f "${f}" ] && cp "${f}" "${staging}/scripts/"
    done
    [ -f "${CLAUDE_DIR}/bin/lstack" ] && cp "${CLAUDE_DIR}/bin/lstack" "${staging}/bin/lstack"

    # Generate settings.json.example — replace absolute HOME paths with ./
    if [ -f "${CLAUDE_DIR}/settings.json" ]; then
        python3 - "${CLAUDE_DIR}/settings.json" "${staging}/settings.json.example" <<'PYEOF' 2>/dev/null || true
import sys, json, re, os
src, dst = sys.argv[1], sys.argv[2]
with open(src) as f:
    raw = f.read()
home = os.path.expanduser('~').replace('\\', '/')
# Replace absolute ~/.claude/... paths with relative ./...
raw = re.sub(re.escape(home) + r'[/\\]\.claude[/\\]', './', raw)
raw = re.sub(re.escape(home.replace('/', '\\')) + r'[/\\]\.claude[/\\]', './', raw)
# Remove personal email/name fields
data = json.loads(raw)
with open(dst, 'w') as f:
    json.dump(data, f, indent=2)
PYEOF
    fi

    # Generate README.md in staging
    cat > "${staging}/README.md" <<'READMEEOF'
# lstack

A personal Claude Code engineering environment — hooks, skills, and CLI tooling
that extend Claude Code with memory, safety gates, git-aware context, and
structured workflows.

## Directory structure

```
~/.claude/
├── CLAUDE.md          # Global identity + rules (loaded every session)
├── bin/lstack         # CLI: init, status, clean, upgrade, publish, dashboard
├── hooks/             # Claude Code lifecycle hooks
│   ├── session-start.sh   # Load memory + git context
│   ├── pre-tool.sh        # Loop detection, bash safety gates, read deduplication
│   ├── post-tool.sh       # Auto-formatter on file writes
│   ├── pre-compact.sh     # Save handover summary before compaction
│   └── stop.sh            # Run tests; auto-extract session learnings
├── scripts/           # Shared utilities
│   ├── os.sh              # Portable OS detection + helper functions
│   └── dashboard.sh       # Live parallel-agent status display
├── skills/            # On-demand skill prompts (invoked via /skillname)
│   ├── engineer.md, planner.md, reviewer.md, refactor.md
│   ├── test.md, debug.md, ship.md, docs.md
│   ├── architect.md, security.md, parallel.md, build.md
└── memory/            # Persistent memory files (auto-updated by Claude)
```

## Installation

```bash
git clone <repo-url> ~/.claude
chmod +x ~/.claude/bin/lstack ~/.claude/hooks/*.sh ~/.claude/scripts/*.sh
~/.claude/bin/lstack init   # scaffold a project
```

## Skills

| Skill | Description |
|-------|-------------|
| /engineer  | Write production code; read patterns first; run tests after |
| /planner   | Structured task breakdown; clarify before planning |
| /reviewer  | Numbered findings: [N] [SEVERITY] [file:line] — [issue] |
| /refactor  | Improve structure; tests before and after |
| /test      | Write tests only; never touch source |
| /debug     | reproduce → isolate → hypothesize → verify → root cause |
| /ship      | Pre-ship checklist: tests, secrets, env vars, changelog |
| /docs      | Read source before writing; never invent API signatures |
| /architect | Design system before coding; outputs ADRs + ARCHITECTURE.md |
| /security  | Security audit; actionable findings only |
| /parallel  | Spawn up to 3 isolated sub-agents in git worktrees |
| /build     | Plan → approve → implement with hard gate between phases |

## Hooks overview

Hooks in `settings.json` enforce rules deterministically:
- **SessionStart** — loads global + project memory, injects git context
- **PreToolUse** — loop detection, bash safety gates, read deduplication
- **PostToolUse** — auto-formats on Write/Edit
- **PreCompact** — saves handover summary before context compaction
- **Stop** — runs project test command; extracts learnings on success
READMEEOF

    echo ""
    echo "Staging: ${staging}"
    echo ""
    echo "Run:"
    echo "  cp -r ${staging} <destination>"
    echo "  # or push directly with git"
}

cmd_doctor() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    local failures=0

    _check_pass() { printf '  [\033[32m✓\033[0m] %s\n' "$1"; }
    _check_fail() { printf '  [\033[31m✗\033[0m] %s\n' "$1"; failures=$(( failures + 1 )); }

    # CLAUDE.md present and under 80 lines
    if [ -f "${CLAUDE_DIR}/CLAUDE.md" ]; then
        local _lines
        _lines="$(wc -l < "${CLAUDE_DIR}/CLAUDE.md" | tr -d ' ')"
        if [ "${_lines}" -le 80 ]; then
            _check_pass "CLAUDE.md present and under 80 lines (${_lines} lines)"
        else
            _check_fail "CLAUDE.md is ${_lines} lines (over 80) — edit and trim: \$EDITOR ~/.claude/CLAUDE.md"
        fi
    else
        _check_fail "CLAUDE.md missing — run: lstack settings"
    fi

    # settings.json valid JSON (use $PYTHON from os.sh — avoids broken Windows stub)
    if [ -f "${CLAUDE_DIR}/settings.json" ] && [ -n "${PYTHON}" ] && \
       "${PYTHON}" -m json.tool "${CLAUDE_DIR}/settings.json" >/dev/null 2>&1; then
        _check_pass "settings.json valid JSON"
    else
        _check_fail "settings.json invalid or missing — run: lstack settings"
    fi

    # All 5 hooks exist and are executable
    local _hooks_ok=true
    for _hook in session-start pre-tool post-tool pre-compact stop; do
        local _hf="${CLAUDE_DIR}/hooks/${_hook}.sh"
        if [ ! -f "${_hf}" ] || [ ! -x "${_hf}" ]; then
            _hooks_ok=false
            break
        fi
    done
    if [ "${_hooks_ok}" = true ]; then
        _check_pass "All 5 hooks exist and are executable"
    else
        _check_fail "One or more hooks missing or not executable — run: chmod +x ~/.claude/hooks/*.sh"
    fi

    # Python 3 (sourced from os.sh)
    if [ -n "${PYTHON}" ]; then
        _check_pass "Python 3 found at: ${PYTHON}"
    else
        _check_fail "Python 3 not found — install python3 (https://python.org)"
    fi

    # DB initialized and accessible
    local _db="${CLAUDE_DIR}/memory/lstack.db"
    if [ -f "${_db}" ]; then
        if [ -n "${PYTHON}" ]; then
            local _stats
            _stats="$("${PYTHON}" "${DB_PY}" stats 2>/dev/null | grep -i 'observation' | head -1 || true)"
            if [ -n "${_stats}" ]; then
                _check_pass "DB accessible: ${_stats}"
            else
                _check_pass "DB initialized at ~/.claude/memory/lstack.db"
            fi
        else
            _check_pass "DB initialized at ~/.claude/memory/lstack.db"
        fi
    else
        _check_fail "DB not initialized — run: python3 ~/.claude/scripts/db.py init"
    fi

    # session-start.sh CLAUDE_HOME check
    if [ -f "${CLAUDE_DIR}/hooks/session-start.sh" ]; then
        if grep -q 'CLAUDE_HOME\|CLAUDE_DIR\|\.claude' "${CLAUDE_DIR}/hooks/session-start.sh" 2>/dev/null; then
            _check_pass "session-start.sh references CLAUDE_HOME/CLAUDE_DIR"
        else
            _check_fail "session-start.sh: may be missing CLAUDE_HOME reference — run: lstack settings"
        fi
    fi

    # git remote configured for upgrade
    if [ -d "${CLAUDE_DIR}/.git" ] && git -C "${CLAUDE_DIR}" remote get-url origin >/dev/null 2>&1; then
        local _remote
        _remote="$(git -C "${CLAUDE_DIR}" remote get-url origin 2>/dev/null)"
        _check_pass "lstack upgrade available (remote: ${_remote})"
    else
        _check_fail "No git remote — upgrade disabled. Run: git -C ~/.claude remote add origin https://github.com/puukis/lstack"
    fi

    # Context7 MCP in settings.json
    if [ -f "${CLAUDE_DIR}/settings.json" ] && grep -q 'context7' "${CLAUDE_DIR}/settings.json" 2>/dev/null; then
        _check_pass "Context7 MCP configured in settings.json"
    else
        _check_fail "Context7 MCP not found in settings.json — run: lstack settings"
    fi

    # statusline script present and executable
    local _sl_sh="${CLAUDE_DIR}/scripts/statusline.sh"
    local _sl_py="${CLAUDE_DIR}/scripts/statusline.py"
    if ( [ -f "${_sl_sh}" ] && [ -x "${_sl_sh}" ] ) || [ -f "${_sl_py}" ]; then
        _check_pass "statusline script present"
    else
        _check_fail "statusline script not executable — run: chmod +x ~/.claude/scripts/statusline.sh"
    fi

    printf '\n'
    if [ "${failures}" -eq 0 ]; then
        printf 'lstack is healthy.\n'
    else
        printf '\033[33m%d check(s) failed.\033[0m Run the fix commands above, then restart Claude Code.\n' "${failures}"
    fi
}

cmd_onboard() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    printf 'Setting up your lstack environment...\n'
    printf '\n'

    # Step A — name/preferences (skip if preferences.md already has content)
    local _prefs="${CLAUDE_DIR}/memory/preferences.md"
    local _has_prefs=false
    if [ -f "${_prefs}" ]; then
        local _pref_content
        _pref_content="$(grep -v '^#' "${_prefs}" | grep -v '^$' | head -1 || true)"
        [ -n "${_pref_content}" ] && _has_prefs=true
    fi

    if [ "${_has_prefs}" = false ]; then
        printf 'What'\''s your name? (used in CLAUDE.md identity) '
        read -r _name
        printf 'Primary coding language(s)? (e.g. TypeScript, Python, Go) '
        read -r _langs
        printf 'Preferred verbosity? [1=minimal 2=normal 3=detailed] '
        read -r _verbosity

        local _verb_label='normal'
        case "${_verbosity}" in
            1) _verb_label='minimal' ;;
            3) _verb_label='detailed' ;;
        esac

        cat > "${_prefs}" <<PREFEOF
# Preferences
# Updated by lstack onboard

Name: ${_name}
Languages: ${_langs}
Verbosity: ${_verb_label}
PREFEOF
        printf 'Preferences saved to ~/.claude/memory/preferences.md\n'
    else
        _name="$(grep '^Name:' "${_prefs}" 2>/dev/null | sed 's/^Name: *//' | head -1 || true)"
        printf 'Preferences already configured (skipping). To reconfigure: edit ~/.claude/memory/preferences.md\n'
    fi

    # Step B — update CLAUDE.md identity line with name
    if [ -n "${_name:-}" ] && [ -f "${CLAUDE_DIR}/CLAUDE.md" ]; then
        if ! grep -q "${_name}" "${CLAUDE_DIR}/CLAUDE.md" 2>/dev/null; then
            # Replace the Owner: line if present, else leave as-is
            if grep -q '^Model:' "${CLAUDE_DIR}/CLAUDE.md" 2>/dev/null; then
                # Insert name line after the Model: line
                local _tmpf
                _tmpf="$(mktemp)"
                awk -v name="${_name}" '
                    /^Model:/ { print; print "Name:  " name; next }
                    { print }
                ' "${CLAUDE_DIR}/CLAUDE.md" > "${_tmpf}"
                mv "${_tmpf}" "${CLAUDE_DIR}/CLAUDE.md"
                printf 'Added your name to CLAUDE.md identity section.\n'
            fi
        fi
    fi

    # Step C — PATH suggestion
    local _bin="${CLAUDE_DIR}/bin"
    case ":${PATH}:" in
        *":${_bin}:"*) ;; # already in PATH
        *)
            printf '\n'
            printf 'Add lstack to your PATH by adding this to your shell config:\n'
            printf '\n'
            local _shell_name
            _shell_name="$(basename "${SHELL:-bash}")"
            case "${_shell_name}" in
                fish)
                    printf '  fish_add_path ~/.claude/bin\n'
                    printf '\n'
                    printf 'Then restart your terminal or run: source ~/.config/fish/config.fish\n'
                    ;;
                *)
                    printf '  export PATH="$HOME/.claude/bin:$PATH"\n'
                    printf '\n'
                    local _rc=".bashrc"
                    [ "${_shell_name}" = "zsh" ] && _rc=".zshrc"
                    printf 'Then restart your terminal or run: source ~/%s\n' "${_rc}"
                    ;;
            esac
            ;;
    esac

    # Step D — Windows-specific check
    case "${OS}" in
        windows)
            printf '\n'
            printf 'Windows detected. Verifying hook paths in settings.json...\n'
            if [ -n "${PYTHON}" ]; then
                "${PYTHON}" "${DB_PY}" init 2>/dev/null || true
                printf 'Python works: %s\n' "${PYTHON}"
            fi
            printf 'Hooks use Git Bash paths (C:/Users/...). Verify in: ~/.claude/settings.json\n'
            printf 'If hooks don'\''t fire, run: lstack settings\n'
            ;;
    esac

    # Step F — sync repo (optional)
    printf '\n'
    printf 'Memory sync across devices (optional).\n'
    printf 'Enter a private git repo URL for cross-device sync,\n'
    printf 'or press Enter to skip: '
    read -r _sync_repo
    if [ -n "${_sync_repo}" ]; then
        printf '%s\n' "${_sync_repo}" > "${CLAUDE_DIR}/memory/.sync-repo"
        printf 'Sync repo saved. Run: lstack sync\n'
    fi

    # Step E — summary
    printf '\n'
    printf 'Onboarding complete. Your setup:\n'
    local _skill_count=0
    if ls "${CLAUDE_DIR}/skills/"*.md >/dev/null 2>&1; then
        _skill_count="$(ls "${CLAUDE_DIR}/skills/"*.md | wc -l | tr -d ' ')"
    fi
    local _hook_count=0
    if ls "${CLAUDE_DIR}/hooks/"*.sh >/dev/null 2>&1; then
        _hook_count="$(ls "${CLAUDE_DIR}/hooks/"*.sh | wc -l | tr -d ' ')"
    fi
    printf '  Skills:  %s skills available\n' "${_skill_count}"
    printf '  Hooks:   %s hooks configured\n' "${_hook_count}"
    local _mem_line='initialized'
    if [ -n "${PYTHON}" ]; then
        _mem_line="$("${PYTHON}" "${DB_PY}" stats 2>/dev/null | grep -i 'observation' | head -1 || echo 'initialized')"
    fi
    printf '  Memory:  %s\n' "${_mem_line}"
    printf '\n'
    printf 'Start a project: cd your-project && lstack init\n'
}

cmd_forget() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    local query="$*"
    if [ -z "${query}" ]; then
        echo "Usage: lstack forget [search terms]"
        echo "Searches and deletes matching observations from persistent memory."
        exit 1
    fi

    echo "Searching for: ${query}"
    results="$("${PYTHON}" "${DB_PY}" search "${query}" --limit 10 2>/dev/null)"
    count="$(printf '%s' "${results}" | "${PYTHON}" -c "
import sys,json
try: print(len(json.load(sys.stdin)))
except: print(0)
" 2>/dev/null || echo 0)"

    if [ "${count}" -eq 0 ]; then
        echo "No observations matched '${query}'"
        exit 0
    fi

    echo ""
    echo "Will delete ${count} observation(s):"
    printf '%s' "${results}" | "${PYTHON}" -c "
import sys,json
try:
    for i,it in enumerate(json.load(sys.stdin),1):
        print(f'  [{i}] {it[\"content\"][:80]}')
except: pass
"
    echo ""
    printf "Delete these? [y/N] "
    read -r confirm
    if [ "${confirm}" != "y" ] && [ "${confirm}" != "Y" ]; then
        echo "Cancelled."
        exit 0
    fi

    result="$("${PYTHON}" "${DB_PY}" forget "${query}" 2>/dev/null)"
    deleted="$(printf '%s' "${result}" | "${PYTHON}" -c "
import sys,json
try: print(json.load(sys.stdin).get('deleted',0))
except: print(0)
")"
    echo "Deleted ${deleted} observation(s)."
}

cmd_edit() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    local query="$*"
    if [ -z "${query}" ]; then
        echo "Usage: lstack edit [search terms]"
        echo "Searches for matching observations, then prompts you to edit one."
        exit 1
    fi

    results="$("${PYTHON}" "${DB_PY}" search "${query}" --limit 10 2>/dev/null)"
    count="$(printf '%s' "${results}" | "${PYTHON}" -c "
import sys,json
try: print(len(json.load(sys.stdin)))
except: print(0)
" 2>/dev/null || echo 0)"

    if [ "${count}" -eq 0 ]; then
        echo "No observations matched '${query}'"
        exit 0
    fi

    echo "Matching observations:"
    printf '%s' "${results}" | "${PYTHON}" -c "
import sys,json
try:
    for i,it in enumerate(json.load(sys.stdin),1):
        oid=it.get('id','?')
        date=(it.get('created_at',''))[:10]
        scope='global' if it.get('project')=='global' else 'project'
        tags=it.get('tags','')
        print(f'  [{i}] id={oid}  {date}  [{scope}]  {it[\"content\"][:70]}')
        if tags:
            print(f'       tags: {tags}')
except Exception as e:
    print(f'Error: {e}')
"

    echo ""
    printf "Observation ID to edit: "
    read -r edit_id
    if [ -z "${edit_id}" ]; then
        echo "Cancelled."
        exit 0
    fi

    printf "Field to edit [content/tags/scope]: "
    read -r field

    case "${field}" in
        content)
            printf "New content: "
            read -r new_val
            result="$("${PYTHON}" "${DB_PY}" edit "${edit_id}" --content "${new_val}" 2>/dev/null)"
            ;;
        tags)
            printf "New tags (comma-separated): "
            read -r new_val
            result="$("${PYTHON}" "${DB_PY}" edit "${edit_id}" --tags "${new_val}" 2>/dev/null)"
            ;;
        scope)
            printf "New scope [project/global]: "
            read -r new_scope
            if [ "${new_scope}" = "global" ]; then
                new_project="global"
            else
                new_project="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
            fi
            result="$("${PYTHON}" "${DB_PY}" edit "${edit_id}" --project "${new_project}" 2>/dev/null)"
            ;;
        *)
            echo "Unknown field '${field}'. Use: content, tags, or scope"
            exit 1
            ;;
    esac

    err="$(printf '%s' "${result}" | "${PYTHON}" -c "
import sys,json
try: print(json.load(sys.stdin).get('error',''))
except: print('')
" 2>/dev/null)"

    if [ -n "${err}" ]; then
        echo "Error: ${err}"
        exit 1
    fi

    echo "Updated observation ${edit_id}."
}

cmd_analytics() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    "${PYTHON}" "${CLAUDE_DIR}/scripts/db.py" analytics
}

cmd_sync() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    local sync_repo_file="${CLAUDE_DIR}/memory/.sync-repo"
    local sync_dir="${CLAUDE_DIR}/memory/sync"

    if [ ! -f "${sync_repo_file}" ]; then
        echo "No sync repo configured."
        echo "Run 'lstack onboard' to set one up, or:"
        echo "  echo 'git@github.com:you/lstack-sync.git' > ~/.claude/memory/.sync-repo"
        exit 1
    fi

    local sync_repo
    sync_repo="$(cat "${sync_repo_file}")"

    if [ ! -d "${sync_dir}/.git" ]; then
        echo "Cloning sync repo..."
        git clone "${sync_repo}" "${sync_dir}" || {
            echo "Clone failed. Check your repo URL and SSH keys."
            exit 1
        }
    fi

    echo "Pulling from sync repo..."
    git -C "${sync_dir}" pull --ff-only origin main 2>/dev/null || \
    git -C "${sync_dir}" pull --ff-only origin master 2>/dev/null || true

    if [ -f "${sync_dir}/observations.json" ]; then
        echo "Importing observations from sync..."
        "${PYTHON}" "${DB_PY}" import "${sync_dir}/observations.json"
    fi

    echo "Exporting current observations..."
    "${PYTHON}" "${DB_PY}" export > "${sync_dir}/observations.json"

    git -C "${sync_dir}" add observations.json
    if ! git -C "${sync_dir}" diff --cached --quiet; then
        git -C "${sync_dir}" commit -m "lstack sync $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
        git -C "${sync_dir}" push origin HEAD
        echo "Sync complete."
    else
        echo "Nothing new to push."
    fi
}

cmd_mcp() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    echo "Starting lstack MCP server (stdio)..."
    echo "To register with Claude Code:"
    echo "  claude mcp add lstack -- python3 ${CLAUDE_DIR}/scripts/mcp_server.py"
    "${PYTHON}" "${CLAUDE_DIR}/scripts/mcp_server.py"
}

cmd_settings() {
    out="${CLAUDE_DIR}/settings.json"
    echo "Regenerating ${out} for current OS..."
    bash "${CLAUDE_DIR}/scripts/gen-settings.sh" > "${out}"
    echo "Done. Validating JSON..."
    python3 -m json.tool "${out}" > /dev/null && echo "settings.json is valid." || echo "Warning: JSON validation failed."
}

# Main dispatch
cmd="${1:-help}"
shift 2>/dev/null || true

case "${cmd}" in
    init)      cmd_init "$@" ;;
    settings)  cmd_settings "$@" ;;
    doctor)    cmd_doctor "$@" ;;
    onboard)   cmd_onboard "$@" ;;
    memory)    cmd_memory "$@" ;;
    search)    cmd_search "$@" ;;
    logs)      cmd_logs "$@" ;;
    status)    cmd_status "$@" ;;
    clean)     cmd_clean "$@" ;;
    dashboard) cmd_dashboard "$@" ;;
    upgrade)   cmd_upgrade "$@" ;;
    publish)   cmd_publish "$@" ;;
    forget)    cmd_forget "$@" ;;
    edit)      cmd_edit "$@" ;;
    analytics) cmd_analytics "$@" ;;
    mcp)       cmd_mcp "$@" ;;
    sync)      cmd_sync "$@" ;;
    help|--help|-h) usage ;;
    *)
        echo "Unknown command: ${cmd}"
        echo ""
        usage
        exit 1
        ;;
esac
