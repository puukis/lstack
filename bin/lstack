#!/usr/bin/env bash
# lstack — personal Claude Code environment CLI

set -euo pipefail

CLAUDE_DIR="${HOME}/.claude"
VERSION="1.0.0"

usage() {
    cat <<EOF
lstack ${VERSION} -- Claude Code personal environment

Commands:
  init              Scaffold .claude/ in current project directory
  settings          Regenerate settings.json for the current OS
  runtime [--json]  Show cross-platform runtime status (OS, Python, Git, paths)
  doctor [--fix] [--json] [--deep]
                    Diagnose (and optionally repair) lstack installation
  health [--json] [--save|--no-save] [--fast|--full] [--history] [--compare]
         [--configure] [--detect]
                    Project quality health dashboard
  onboard           Interactive first-run setup
  memory            Open project or global MEMORY.md in \$EDITOR
  memory stats      Show persistent DB stats
  memory list           List all observations (current project + global)
  memory list --global  List only global observations
  memory list --tag X   Filter by tag
  memory prune [--days N]  Delete observations older than N days (default 90)
  search [query]    Search persistent memory for [query]
  logs              Tail tool-calls.log with color
  status            Show hook health, memory sizes, session/compaction timestamps
  freeze PATH       Restrict Edit/Write/MultiEdit to path(s) for this session
  unfreeze          Clear the current session freeze boundary
  guard PATH        Enable careful safety mode plus freeze boundary
  safety status     Show safety mode and freeze boundary state
  safety careful    Ask before risky Bash commands this session
  safety strict     Deny risky Bash commands this session
  safety off        Disable opt-in safety checks this session
  clean             Prune logs >30 days; remove loop/reads state for dead PIDs
  dashboard         Live display of parallel agent worktrees
  upgrade           Pull latest lstack from git origin
  publish           Package lstack for open-source sharing
  forget [query]    Delete matching observations from persistent memory
  edit [query]      Search and interactively edit an observation
  analytics         Show memory analytics -- observations per week, top tags, scope breakdown
  mcp               Start lstack MCP server (stdio transport)
  memory embed-all  Backfill semantic embeddings for all observations
  brain             LBrain local trust brain: passport, attempts, decisions, capture, context, doctor
  learn             Manage structured learnings
  sync              Sync memory to/from a private git repo (cross-device)
  help              Show this message
EOF
}

cmd_init() {
    local project_dir
    project_dir="$(pwd)"

    if [ -d "${project_dir}/.claude" ]; then
        echo "Error: .claude/ already exists in ${project_dir}"
        exit 1
    fi

    echo "Initializing lstack project in ${project_dir}..."

    # Auto-detect project context
    echo "Scanning project..."

    detected_stack=""
    detected_test=""
    detected_dev=""
    detected_build=""
    detected_lint=""
    detected_name="$(basename "$(pwd)")"

    # Node / TypeScript
    if [ -f "package.json" ]; then
        pkg_name="$(run_python -c "
import json
try:
  d=json.load(open('package.json'))
  print(d.get('name',''))
except: print('')
" 2>/dev/null)"
        [ -n "${pkg_name}" ] && detected_name="${pkg_name}"

        detected_test="$(run_python -c "
import json
try:
  s=json.load(open('package.json')).get('scripts',{})
  for k in ['test','jest','vitest']:
      if k in s: print(f'npm test'); break
  else: print('')
except: print('')
" 2>/dev/null)"
        detected_dev="$(run_python -c "
import json
try:
  s=json.load(open('package.json')).get('scripts',{})
  for k in ['dev','start','serve']:
      if k in s: print(f'npm run {k}'); break
except: print('')
" 2>/dev/null)"
        detected_build="$(run_python -c "
import json
try:
  s=json.load(open('package.json')).get('scripts',{})
  if 'build' in s: print('npm run build')
except: print('')
" 2>/dev/null)"

        if [ -f "tsconfig.json" ]; then
            detected_stack="TypeScript/Node"
        else
            detected_stack="JavaScript/Node"
        fi
        if [ -f "next.config.js" ] || [ -f "next.config.ts" ]; then
            detected_stack="TypeScript/Next.js"
        elif grep -q '"react"' package.json 2>/dev/null; then
            detected_stack="TypeScript/React"
        fi
        if [ -f ".eslintrc.json" ] || [ -f ".eslintrc.js" ] || [ -f "eslint.config.js" ]; then
            detected_lint="npm run lint"
        fi
    fi

    # Python
    if [ -f "pyproject.toml" ] || [ -f "setup.py" ] || [ -f "requirements.txt" ]; then
        detected_stack="Python"
        if [ -f "pyproject.toml" ]; then
            detected_test="pytest"
            detected_lint="ruff check ."
        fi
        if grep -q "fastapi" requirements.txt 2>/dev/null || \
           grep -q "fastapi" pyproject.toml 2>/dev/null; then
            detected_stack="Python/FastAPI"
            detected_dev="uvicorn main:app --reload"
        fi
    fi

    # Go
    if [ -f "go.mod" ]; then
        detected_stack="Go"
        detected_test="go test ./..."
        detected_build="go build ./..."
        detected_lint="golangci-lint run"
        detected_name="$(head -1 go.mod | awk '{print $2}' | xargs basename 2>/dev/null || echo "${detected_name}")"
    fi

    # Rust
    if [ -f "Cargo.toml" ]; then
        detected_stack="Rust"
        detected_test="cargo test"
        detected_build="cargo build --release"
        detected_lint="cargo clippy"
    fi

    printf '\nDetected project info (press Enter to accept, or type to override):\n\n'

    printf "Project name [${detected_name}]: "
    read -r project_name
    project_name="${project_name:-${detected_name}}"

    printf "Tech stack [${detected_stack:-unknown}]: "
    read -r project_stack
    project_stack="${project_stack:-${detected_stack}}"

    printf "Test command [${detected_test:-none}]: "
    read -r test_cmd
    test_cmd="${test_cmd:-${detected_test}}"

    printf "Dev command [${detected_dev:-none}]: "
    read -r dev_cmd
    dev_cmd="${dev_cmd:-${detected_dev}}"

    printf "Build command [${detected_build:-none}]: "
    read -r build_cmd
    build_cmd="${build_cmd:-${detected_build}}"

    printf "Lint command [${detected_lint:-none}]: "
    read -r lint_cmd
    lint_cmd="${lint_cmd:-${detected_lint}}"

    printf "Purpose (one line): "
    read -r purpose

    # Create directories
    mkdir -p "${project_dir}/.claude/memory"
    mkdir -p "${project_dir}/.claude/logs"

    # Write project CLAUDE.md
    cat > "${project_dir}/.claude/CLAUDE.md" <<CLAUDEEOF
## Project
Name:    ${project_name}
Stack:   ${project_stack}
Purpose: ${purpose}

## Build & Test
dev:   ${dev_cmd}
build: ${build_cmd}
test:  ${test_cmd}
lint:  ${lint_cmd}

## Architecture
<!-- 2-3 sentences max: how is the code organized? -->

## Conventions
<!-- One rule per bullet. -->
- Follow existing patterns in the codebase before introducing new ones
- All new code must have tests

## Memory
See .claude/memory/MEMORY.md
CLAUDEEOF

    # Write project MEMORY.md
    cat > "${project_dir}/.claude/memory/MEMORY.md" <<MEMEOF
# ${project_name} — project memory index
# Keep lean. Claude updates this as context accumulates.

## Architecture
See architecture.md

## Debugging
See debugging.md

## Conventions
See conventions.md
MEMEOF

    # Write empty memory files
    printf '# Architecture\n<!-- Key architectural decisions and rationale -->\n' > "${project_dir}/.claude/memory/architecture.md"
    printf '# Debugging\n<!-- Known issues, root causes, reproduction steps -->\n' > "${project_dir}/.claude/memory/debugging.md"
    printf '# Conventions\n<!-- Project-specific coding conventions -->\n' > "${project_dir}/.claude/memory/conventions.md"

    # Add logs to .gitignore
    if [ -f "${project_dir}/.gitignore" ]; then
        if ! grep -q '\.claude/logs' "${project_dir}/.gitignore"; then
            printf '\n# Claude Code lstack logs\n.claude/logs/\n.claude/memory/handover.md\n' >> "${project_dir}/.gitignore"
        fi
    else
        printf '# Claude Code lstack logs\n.claude/logs/\n.claude/memory/handover.md\n' > "${project_dir}/.gitignore"
    fi

    echo ""
    echo "Done. Created:"
    echo "  .claude/CLAUDE.md"
    echo "  .claude/memory/MEMORY.md"
    echo "  .claude/memory/architecture.md"
    echo "  .claude/memory/debugging.md"
    echo "  .claude/memory/conventions.md"
    echo ""
    echo "Next: Edit .claude/CLAUDE.md to fill in Architecture and Conventions."

    # Regenerate global settings.json for current OS
    bash "${CLAUDE_DIR}/scripts/gen-settings.sh" > "${CLAUDE_DIR}/settings.json" 2>/dev/null && \
        echo "settings.json regenerated for current OS." || \
        echo "Warning: could not regenerate settings.json (run: lstack settings)"
}

cmd_memory() {
    local subcmd="${1:-}"
    shift 2>/dev/null || true

    case "${subcmd}" in
        stats)
            source "${CLAUDE_DIR}/scripts/os.sh"
            run_python "${CLAUDE_DIR}/scripts/db.py" stats
            ;;
        prune)
            source "${CLAUDE_DIR}/scripts/os.sh"
            run_python "${CLAUDE_DIR}/scripts/db.py" prune "$@"
            ;;
        embed-all)
            source "${CLAUDE_DIR}/scripts/os.sh"
            run_python "${CLAUDE_DIR}/scripts/db.py" embed-all
            ;;
        list)
            source "${CLAUDE_DIR}/scripts/os.sh"
            run_python "${CLAUDE_DIR}/scripts/db.py" list "$@"
            ;;
        "")
            local editor="${EDITOR:-nano}"
            local target
            git_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
            if [ -n "${git_root}" ] && [ -f "${git_root}/.claude/memory/MEMORY.md" ]; then
                target="${git_root}/.claude/memory/MEMORY.md"
                echo "Opening project memory: ${target}"
            else
                target="${CLAUDE_DIR}/memory/MEMORY.md"
                echo "Opening global memory: ${target}"
            fi
            "${editor}" "${target}"
            ;;
        *)
            echo "Unknown memory subcommand: ${subcmd}"
            echo "Usage: lstack memory [stats|prune [--days N]|embed-all]"
            exit 1
            ;;
    esac
}

cmd_brain() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    if [ "${PYTHON_AVAILABLE:-false}" != "true" ]; then
        echo "Error: Python 3 is required for lstack brain. On Windows Git Bash, ensure py -3 works." >&2
        exit 5
    fi
    run_python "${CLAUDE_DIR}/lbrain/brain.py" "$@"
}

cmd_search() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    local query="$*"
    if [ -z "${query}" ]; then
        echo "Usage: lstack search [query]"
        exit 1
    fi

    results="$(run_python "${CLAUDE_DIR}/scripts/db.py" search "${query}" --limit 5 2>/dev/null)"

    count="$(printf '%s' "${results}" | run_python -c "
import sys,json
try: print(len(json.load(sys.stdin)))
except: print(0)
" 2>/dev/null || echo "0")"

    if [ "${count}" -eq 0 ]; then
        echo "No results for '${query}'"
        exit 0
    fi

    printf '%s' "${results}" | run_python -c "
import sys,json
try:
    items=json.load(sys.stdin)
    for i,it in enumerate(items,1):
        content=it.get('content','')
        date=(it.get('created_at',''))[:10]
        tags=it.get('tags','')
        print(f'[{i}] {date}  {content}')
        if tags:
            print(f'     tags: {tags}')
except Exception as e:
    print(f'Error: {e}')
"
}

cmd_logs() {
    local log_file="${CLAUDE_DIR}/logs/tool-calls.log"

    if [ ! -f "${log_file}" ]; then
        echo "No tool-calls.log found. Start a Claude session to generate logs."
        exit 0
    fi

    # Tail with color: blocked=red, timestamps=dim
    tail -f "${log_file}" | awk '
    {
        line = $0
        if (line ~ /Blocked|blocked|BLOCKED|exit 2/) {
            printf "\033[31m%s\033[0m\n", line
        } else if (line ~ /^\[20[0-9][0-9]-/) {
            # Dim the ISO timestamp portion
            printf "\033[2m%s\033[0m\n", line
        } else {
            print line
        }
        fflush()
    }'
}

cmd_status() {
    echo "=== lstack status ==="
    echo ""

    # Hook health
    echo "--- Hooks ---"
    for hook in session-start pre-tool post-tool pre-compact stop; do
        f="${CLAUDE_DIR}/hooks/${hook}.sh"
        if [ -f "${f}" ]; then
            if [ -x "${f}" ]; then
                echo "  ✓ ${hook}.sh (executable)"
            else
                echo "  ✗ ${hook}.sh (NOT executable)"
            fi
        else
            echo "  ✗ ${hook}.sh (MISSING)"
        fi
    done

    echo ""
    echo "--- Memory files ---"
    for mf in MEMORY.md preferences.md patterns.md projects.md; do
        f="${CLAUDE_DIR}/memory/${mf}"
        if [ -f "${f}" ]; then
            size="$(wc -c < "${f}" 2>/dev/null | tr -d ' ')"
            echo "  ${mf}: ${size} bytes"
        else
            echo "  ${mf}: MISSING"
        fi
    done

    echo ""
    echo "--- Last session ---"
    session_log="${CLAUDE_DIR}/logs/sessions.log"
    if [ -f "${session_log}" ]; then
        tail -3 "${session_log}"
    else
        echo "  No sessions logged yet"
    fi

    echo ""
    echo "--- Last compaction ---"
    compact_log="${CLAUDE_DIR}/logs/compactions.log"
    if [ -f "${compact_log}" ]; then
        tail -1 "${compact_log}"
    else
        echo "  No compactions logged yet"
    fi

    echo ""
    echo "--- Loop state files ---"
    log_dir="${CLAUDE_DIR}/logs"
    if [ -d "${log_dir}" ]; then
        loop_count=0
        for _lf in "${log_dir}"/loop-*.json; do
            [ -f "${_lf}" ] && loop_count=$(( loop_count + 1 )) || true
        done
        echo "  Active loop state files: ${loop_count}"
        if [ "${loop_count}" -gt 0 ] 2>/dev/null; then
            bash "${CLAUDE_DIR}/scripts/loop-detector.sh" 2>/dev/null || true
        fi
    else
        echo "  Log directory not found"
    fi
}

cmd_freeze() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    run_python "${CLAUDE_DIR}/scripts/safety.py" freeze "$@"
}

cmd_unfreeze() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    run_python "${CLAUDE_DIR}/scripts/safety.py" freeze --clear
}

cmd_safety() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    local subcmd="${1:-status}"
    shift 2>/dev/null || true
    run_python "${CLAUDE_DIR}/scripts/safety.py" safety "${subcmd}" "$@"
}

cmd_guard() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    run_python "${CLAUDE_DIR}/scripts/safety.py" guard "$@"
}

cmd_clean() {
    local log_dir="${CLAUDE_DIR}/logs"
    echo "Cleaning lstack logs..."

    if [ ! -d "${log_dir}" ]; then
        echo "No log directory found."
        exit 0
    fi

    # Prune log files older than 30 days (excluding loop state files)
    old_count=0
    for f in "${log_dir}"/*.log; do
        [ -f "${f}" ] || continue
        if find "${f}" -mtime +30 -print 2>/dev/null | grep -q .; then
            rm -f "${f}"
            old_count=$(( old_count + 1 ))
        fi
    done
    echo "  Removed ${old_count} log file(s) older than 30 days"

    # Remove loop state files for dead PIDs
    dead_count=0
    for f in "${log_dir}"/loop-*.json; do
        [ -f "${f}" ] || continue
        pid="$(basename "${f}" | sed 's/loop-//;s/\.json//')"
        if ! kill -0 "${pid}" 2>/dev/null; then
            rm -f "${f}"
            dead_count=$(( dead_count + 1 ))
        fi
    done
    echo "  Removed ${dead_count} loop state file(s) for dead PIDs"

    # Remove reads state files for dead PIDs
    reads_count=0
    for f in "${log_dir}"/reads-*.json; do
        [ -f "${f}" ] || continue
        pid="$(basename "${f}" | sed 's/reads-//;s/\.json//')"
        if ! kill -0 "${pid}" 2>/dev/null; then
            rm -f "${f}"
            reads_count=$(( reads_count + 1 ))
        fi
    done
    echo "  Removed ${reads_count} reads state file(s) for dead PIDs"

    # Remove semantic loop state files for dead PIDs
    errloop_count=0
    for f in "${log_dir}"/errloop-*.json; do
        [ -f "${f}" ] || continue
        pid="$(basename "${f}" | sed 's/errloop-//;s/\.json//')"
        if ! kill -0 "${pid}" 2>/dev/null; then
            rm -f "${f}"
            errloop_count=$(( errloop_count + 1 ))
        fi
    done
    echo "  Removed ${errloop_count} semantic loop state file(s) for dead PIDs"

    # Prune persistent DB observations older than 90 days
    source "${CLAUDE_DIR}/scripts/os.sh"
    if [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
        db_prune_out="$(run_python "${CLAUDE_DIR}/scripts/db.py" prune --days 90 2>/dev/null || echo "  (db.py not available)")"
        echo "  ${db_prune_out}"
    fi

    echo "Done."
}

cmd_dashboard() {
    exec bash "${CLAUDE_DIR}/scripts/dashboard.sh"
}

cmd_upgrade() {
    local git_dir="${CLAUDE_DIR}/.git"
    local git_source="${CLAUDE_DIR}/.git-source"

    if [ ! -d "${git_dir}" ]; then
        cat <<EOF
lstack was not installed via git. Cannot auto-upgrade.
To enable upgrades: git init ~/.claude && git remote add origin [your-repo-url]
EOF
        exit 1
    fi

    if ! git -C "${CLAUDE_DIR}" remote get-url origin >/dev/null 2>&1; then
        echo "No 'origin' remote configured."
        echo "Add one with: git -C ~/.claude remote add origin [url]"
        exit 1
    fi

    # Write .git-source if not present
    if [ ! -f "${git_source}" ]; then
        git -C "${CLAUDE_DIR}" remote get-url origin > "${git_source}" 2>/dev/null || true
    fi

    git -C "${CLAUDE_DIR}" fetch origin

    local local_sha remote_sha
    local_sha="$(git -C "${CLAUDE_DIR}" rev-parse HEAD 2>/dev/null)"
    remote_sha="$(git -C "${CLAUDE_DIR}" rev-parse origin/main 2>/dev/null)"

    if [ "${local_sha}" = "${remote_sha}" ]; then
        echo "Already up to date."
        exit 0
    fi

    local local_short="${local_sha:0:7}"
    local remote_short="${remote_sha:0:7}"
    echo "Updating lstack: ${local_short} -> ${remote_short}"

    git -C "${CLAUDE_DIR}" pull --ff-only origin main

    echo "Updated. Changes:"
    git -C "${CLAUDE_DIR}" log --oneline "${local_sha}..${remote_sha}"
    echo ""
    echo "Restart Claude Code to apply changes."
}

cmd_publish() {
    local timestamp
    timestamp="$(date -u '+%Y%m%dT%H%M%S' 2>/dev/null || echo 'now')"
    local staging="/tmp/lstack-publish-${timestamp}"

    echo "Creating staging directory: ${staging}"
    mkdir -p "${staging}/skills" "${staging}/hooks" "${staging}/scripts" "${staging}/bin" \
             "${staging}/lbrain/brain" "${staging}/docs"

    # Explicit copies — no wildcards that could grab sensitive files
    [ -f "${CLAUDE_DIR}/CLAUDE.md" ] && cp "${CLAUDE_DIR}/CLAUDE.md" "${staging}/CLAUDE.md"

    for f in "${CLAUDE_DIR}/skills/"*.md; do
        [ -f "${f}" ] && cp "${f}" "${staging}/skills/"
    done
    for f in "${CLAUDE_DIR}/hooks/"*.sh; do
        [ -f "${f}" ] && cp "${f}" "${staging}/hooks/"
    done
    for f in "${CLAUDE_DIR}/scripts/"*.sh; do
        [ -f "${f}" ] && cp "${f}" "${staging}/scripts/"
    done
    for f in "${CLAUDE_DIR}/scripts/"*.py; do
        [ -f "${f}" ] && cp "${f}" "${staging}/scripts/"
    done
    for f in "${CLAUDE_DIR}/lbrain/"*.py; do
        [ -f "${f}" ] && cp "${f}" "${staging}/lbrain/"
    done
    for f in "${CLAUDE_DIR}/lbrain/brain/"*.py; do
        [ -f "${f}" ] && cp "${f}" "${staging}/lbrain/brain/"
    done
    [ -f "${CLAUDE_DIR}/docs/lbrain.md" ] && cp "${CLAUDE_DIR}/docs/lbrain.md" "${staging}/docs/lbrain.md"
    [ -f "${CLAUDE_DIR}/bin/lstack" ] && cp "${CLAUDE_DIR}/bin/lstack" "${staging}/bin/lstack"

    # Generate settings.json.example — replace absolute HOME paths with ./
    if [ -f "${CLAUDE_DIR}/settings.json" ]; then
        run_python - "${CLAUDE_DIR}/settings.json" "${staging}/settings.json.example" <<'PYEOF' 2>/dev/null || true
import sys, json, re, os
src, dst = sys.argv[1], sys.argv[2]
with open(src) as f:
    raw = f.read()
home = os.path.expanduser('~').replace('\\', '/')
# Replace absolute ~/.claude/... paths with relative ./...
raw = re.sub(re.escape(home) + r'[/\\]\.claude[/\\]', './', raw)
raw = re.sub(re.escape(home.replace('/', '\\')) + r'[/\\]\.claude[/\\]', './', raw)
# Remove personal email/name fields
data = json.loads(raw)
with open(dst, 'w') as f:
    json.dump(data, f, indent=2)
PYEOF
    fi

    # Generate README.md in staging
    cat > "${staging}/README.md" <<'READMEEOF'
# lstack

A personal Claude Code engineering environment — hooks, skills, and CLI tooling
that extend Claude Code with memory, safety gates, git-aware context, and
structured workflows.

## Directory structure

```
~/.claude/
├── CLAUDE.md          # Global identity + rules (loaded every session)
├── bin/lstack         # CLI: init, status, brain, clean, upgrade, publish
├── hooks/             # Claude Code lifecycle hooks
│   ├── session-start.sh   # Load memory + git context
│   ├── pre-tool.sh        # Loop detection, bash safety gates, read deduplication
│   ├── post-tool.sh       # Auto-formatter on file writes
│   ├── pre-compact.sh     # Save handover summary before compaction
│   └── stop.sh            # Run tests; auto-extract session learnings
├── scripts/           # Shared utilities
│   ├── os.sh              # Portable OS detection + helper functions
│   └── dashboard.sh       # Live parallel-agent status display
├── lbrain/            # LBrain local trust brain
│   ├── brain.py           # lstack brain CLI entrypoint
│   └── brain/             # Repo passport, attempts, context, redaction
├── skills/            # On-demand skill prompts (invoked via /skillname)
│   ├── engineer.md, planner.md, reviewer.md, refactor.md
│   ├── test.md, debug.md, ship.md, docs.md
│   ├── architect.md, security.md, parallel.md, build.md
└── memory/            # Persistent memory files (auto-updated by Claude)
```

## Installation

```bash
git clone <repo-url> ~/.claude
chmod +x ~/.claude/bin/lstack ~/.claude/hooks/*.sh ~/.claude/scripts/*.sh
~/.claude/bin/lstack init   # scaffold a project
```

## Skills

| Skill | Description |
|-------|-------------|
| /engineer  | Write production code; read patterns first; run tests after |
| /planner   | Structured task breakdown; clarify before planning |
| /reviewer  | Numbered findings: [N] [SEVERITY] [file:line] — [issue] |
| /refactor  | Improve structure; tests before and after |
| /test      | Write tests only; never touch source |
| /debug     | reproduce → isolate → hypothesize → verify → root cause |
| /ship      | Pre-ship checklist: tests, secrets, env vars, changelog |
| /docs      | Read source before writing; never invent API signatures |
| /architect | Design system before coding; outputs ADRs + ARCHITECTURE.md |
| /security  | Security audit; actionable findings only |
| /parallel  | Spawn up to 3 isolated sub-agents in git worktrees |
| /build     | Plan → approve → implement with hard gate between phases |

## Hooks overview

Hooks in `settings.json` enforce rules deterministically:
- **SessionStart** — loads global + project memory, injects git context
- **PreToolUse** — loop detection, bash safety gates, read deduplication
- **PostToolUse** — auto-formats on Write/Edit
- **PreCompact** — saves handover summary before context compaction
- **Stop** — runs project test command; extracts learnings on success
READMEEOF

    echo ""
    echo "Staging: ${staging}"
    echo ""
    echo "Run:"
    echo "  cp -r ${staging} <destination>"
    echo "  # or push directly with git"
}

cmd_runtime() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    if [ -f "${CLAUDE_DIR}/scripts/runtime.sh" ]; then
        # shellcheck source=scripts/runtime.sh
        source "${CLAUDE_DIR}/scripts/runtime.sh"
    fi

    local do_json=false
    for _a in "$@"; do
        [ "${_a}" = "--json" ] && do_json=true
    done

    local _py_ver=""
    if [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
        _py_ver="$(run_python -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}.{sys.version_info.micro}')" 2>/dev/null || echo "unknown")"
    fi
    local _py_label
    _py_label="$(python_provider_label 2>/dev/null || echo "unavailable")"

    local _git_ver=""
    _git_ver="$(git --version 2>/dev/null | awk '{print $3}' || echo "")"
    local _git_avail="false"
    [ -n "${_git_ver}" ] && _git_avail="true"

    local _claude_path=""
    _claude_path="$(command -v claude 2>/dev/null || true)"

    local _claude_type="native"
    if [ -n "${_claude_path}" ] && [ "${OS:-linux}" = "windows" ]; then
        case "${_claude_path}" in
            *.exe) _claude_type="Windows PE (native) on Git Bash" ;;
            *)     _claude_type="shell wrapper or unknown" ;;
        esac
    fi

    local _settings_path="${CLAUDE_DIR}/settings.json"
    local _db_path="${CLAUDE_DIR}/memory/lstack.db"
    local _path_sample=""
    if type normalize_hook_path >/dev/null 2>&1; then
        _path_sample="$(normalize_hook_path "${HOME}/.claude" 2>/dev/null || echo "${HOME}/.claude")"
    else
        _path_sample="${HOME}/.claude"
    fi

    if [ "${do_json}" = "true" ]; then
        run_python -c "
import json, os, sys
print(json.dumps({
  'os': '${OS:-unknown}',
  'shell': '${BASH_VERSION:-unknown}',
  'home': os.path.expanduser('~'),
  'claude_dir': '${CLAUDE_DIR}',
  'python_available': ${PYTHON_AVAILABLE:-false},
  'python_provider': '${_py_label}',
  'python_version': '${_py_ver}',
  'git_available': ${_git_avail},
  'git_version': '${_git_ver}',
  'claude_path': '${_claude_path}',
  'claude_type': '${_claude_type}',
  'settings_path': '${_settings_path}',
  'db_path': '${_db_path}',
  'path_sample': '${_path_sample}'
}, indent=2))
" 2>/dev/null || printf '{"error":"Python unavailable for JSON output"}\n'
        return 0
    fi

    printf 'lstack runtime status\n\n'
    printf '%-18s %s\n' 'OS:'            "${OS:-unknown}"
    printf '%-18s %s\n' 'Shell:'         "bash ${BASH_VERSION:-unknown}"
    printf '%-18s %s\n' 'HOME:'          "${HOME}"
    printf '%-18s %s\n' 'CLAUDE_DIR:'    "${CLAUDE_DIR}"
    if [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
        printf '%-18s %s\n' 'Python:'        "available"
        printf '%-18s %s\n' 'Python provider:' "${_py_label}"
        printf '%-18s %s\n' 'Python version:' "${_py_ver}"
    else
        printf '%-18s %s\n' 'Python:'        "NOT FOUND"
        printf '%-18s %s\n' 'Python provider:' "none"
    fi
    if [ "${_git_avail}" = "true" ]; then
        printf '%-18s %s\n' 'Git:'           "available (${_git_ver})"
    else
        printf '%-18s %s\n' 'Git:'           "NOT FOUND"
    fi
    if [ -n "${_claude_path}" ]; then
        printf '%-18s %s\n' 'Claude path:'   "${_claude_path}"
        [ "${OS:-linux}" = "windows" ] && printf '%-18s %s\n' 'Claude type:'   "${_claude_type}"
    else
        printf '%-18s %s\n' 'Claude path:'   "(not in PATH)"
    fi
    printf '%-18s %s\n' 'Settings path:' "${_settings_path}"
    printf '%-18s %s\n' 'DB path:'       "${_db_path}"
    printf '%-18s %s -> %s\n' 'Path sample:' '~/.claude' "${_path_sample}"
}

cmd_doctor() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    if [ -f "${CLAUDE_DIR}/scripts/runtime.sh" ]; then
        # shellcheck source=scripts/runtime.sh
        source "${CLAUDE_DIR}/scripts/runtime.sh"
    fi

    local do_fix=false do_json=false do_deep=false
    for _a in "$@"; do
        case "${_a}" in
            --fix)  do_fix=true ;;
            --json) do_json=true ;;
            --deep) do_deep=true ;;
        esac
    done

    # Accumulate check results: "id|category|severity|message|fixable|fixed"
    local _results=()
    local _n_pass=0 _n_warn=0 _n_fail=0
    local _overall="pass"

    _dr_record() {
        local _id="$1" _cat="$2" _sev="$3" _msg="$4" _fixable="${5:-false}" _fixed="${6:-false}"
        _results+=("${_id}|${_cat}|${_sev}|${_msg}|${_fixable}|${_fixed}")
        case "${_sev}" in
            pass) _n_pass=$(( _n_pass + 1 )) ;;
            warn) _n_warn=$(( _n_warn + 1 )); if [ "${_overall}" = "pass" ]; then _overall="warn"; fi ;;
            fail) _n_fail=$(( _n_fail + 1 )); _overall="fail" ;;
        esac
    }

    _dr_backup() {
        local _f="$1"
        [ -f "${_f}" ] || return 0
        local _ts
        _ts="$(date -u '+%Y%m%d%H%M%S')"
        cp "${_f}" "${_f}.bak.${_ts}" 2>/dev/null || true
    }

    # --- Runtime checks ---
    _dr_record "runtime.os" "runtime" "pass" "OS: ${OS:-unknown}"

    if [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
        local _pver
        _pver="$(run_python -c "import sys; print(f'{sys.version_info.major}.{sys.version_info.minor}')" 2>/dev/null || echo "?")"
        _dr_record "runtime.python" "runtime" "pass" "Python ${_pver} via $(basename "$(python_provider_label 2>/dev/null || echo python3)")"
        if run_python -c "import sys; assert sys.version_info.major == 3" >/dev/null 2>&1; then
            _dr_record "runtime.python_version" "runtime" "pass" "Python version is 3.x"
        else
            _dr_record "runtime.python_version" "runtime" "fail" "Python found but not version 3" "false"
        fi
    else
        _dr_record "runtime.python" "runtime" "fail" \
            "Python 3 not found. Install from python.org or ensure py -3 works (Windows Git Bash)" \
            "false"
    fi

    if command -v git >/dev/null 2>&1; then
        _dr_record "runtime.git" "runtime" "pass" "Git available: $(git --version 2>/dev/null | awk '{print $3}')"
    else
        _dr_record "runtime.git" "runtime" "warn" "Git not found in PATH"
    fi

    local _lstack_bin="${CLAUDE_DIR}/bin"
    case ":${PATH}:" in
        *":${_lstack_bin}:"*) _dr_record "runtime.path" "runtime" "pass" "~/.claude/bin is in PATH" ;;
        *) _dr_record "runtime.path" "runtime" "warn" "~/.claude/bin not in PATH -- add: export PATH=\"\$HOME/.claude/bin:\$PATH\"" ;;
    esac

    # Detect broken Windows Store Python stub
    if [ "${OS:-linux}" = "windows" ] && command -v python >/dev/null 2>&1; then
        local _py_loc
        _py_loc="$(command -v python 2>/dev/null || true)"
        case "${_py_loc}" in
            */WindowsApps/*)
                _dr_record "runtime.python_stub" "runtime" "fail" \
                    "Windows Store Python stub detected at ${_py_loc} -- it does not work in Git Bash. Install real Python." "false"
                ;;
        esac
    fi

    # --- Installation checks ---
    if [ -d "${CLAUDE_DIR}" ]; then
        _dr_record "install.claude_dir" "installation" "pass" "~/.claude exists"
    else
        _dr_record "install.claude_dir" "installation" "fail" "~/.claude missing -- run the installer" "false"
    fi

    if [ -f "${CLAUDE_DIR}/bin/lstack" ]; then
        _dr_record "install.lstack_bin" "installation" "pass" "~/.claude/bin/lstack exists"
    else
        _dr_record "install.lstack_bin" "installation" "fail" "~/.claude/bin/lstack missing -- reinstall" "false"
    fi

    # Hooks
    for _hook in session-start pre-tool post-tool pre-compact stop; do
        local _hf="${CLAUDE_DIR}/hooks/${_hook}.sh"
        if [ ! -f "${_hf}" ]; then
            _dr_record "install.hook.${_hook}" "installation" "fail" "Hook missing: hooks/${_hook}.sh" "false"
        elif [ "${OS:-linux}" != "windows" ] && [ ! -x "${_hf}" ]; then
            _dr_record "install.hook.${_hook}" "installation" "fail" \
                "Hook not executable: hooks/${_hook}.sh" "true" \
                "$([ "${do_fix}" = "true" ] && { chmod +x "${_hf}" && echo "true"; } || echo "false")"
        else
            _dr_record "install.hook.${_hook}" "installation" "pass" "Hook OK: hooks/${_hook}.sh"
        fi
    done

    # settings.json
    local _sj="${CLAUDE_DIR}/settings.json"
    if [ ! -f "${_sj}" ]; then
        if [ "${do_fix}" = "true" ]; then
            bash "${CLAUDE_DIR}/scripts/gen-settings.sh" > "${_sj}" 2>/dev/null || true
            _dr_record "install.settings_json" "installation" "fail" "settings.json was missing -- regenerated" "true" "true"
        else
            _dr_record "install.settings_json" "installation" "fail" "settings.json missing -- run: lstack settings" "true"
        fi
    elif [ "${PYTHON_AVAILABLE:-false}" = "true" ] && ! run_python -m json.tool "${_sj}" >/dev/null 2>&1; then
        if [ "${do_fix}" = "true" ]; then
            _dr_backup "${_sj}"
            bash "${CLAUDE_DIR}/scripts/gen-settings.sh" > "${_sj}" 2>/dev/null || true
            _dr_record "install.settings_json" "installation" "fail" "settings.json was invalid -- regenerated from backup" "true" "true"
        else
            _dr_record "install.settings_json" "installation" "fail" "settings.json invalid JSON -- run: lstack settings" "true"
        fi
    else
        _dr_record "install.settings_json" "installation" "pass" "settings.json valid JSON"
    fi

    # Stop timeout check
    if [ -f "${_sj}" ] && [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
        local _stop_timeout
        _stop_timeout="$(run_python -c "
import json, sys
try:
    d = json.load(open('${_sj}'))
    hooks = d.get('hooks', {})
    for h in hooks.get('Stop', hooks.get('stop', [])):
        t = h.get('timeout', 0)
        if t: print(t); sys.exit(0)
    print(0)
except: print(0)
" 2>/dev/null || echo "0")"
        if [ "${_stop_timeout}" -ge 90 ] 2>/dev/null; then
            _dr_record "install.stop_timeout" "installation" "pass" "Stop hook timeout: ${_stop_timeout}s"
        else
            if [ "${do_fix}" = "true" ]; then
                _dr_backup "${_sj}"
                bash "${CLAUDE_DIR}/scripts/gen-settings.sh" > "${_sj}" 2>/dev/null || true
                _dr_record "install.stop_timeout" "installation" "fail" \
                    "Stop timeout was ${_stop_timeout}s (need >=90) -- regenerated settings.json" "true" "true"
            else
                _dr_record "install.stop_timeout" "installation" "fail" \
                    "Stop timeout is ${_stop_timeout}s, expected >=90 -- run: lstack doctor --fix" "true"
            fi
        fi
    fi

    # --- Memory checks ---
    local _mem_dir="${CLAUDE_DIR}/memory"
    if [ -d "${_mem_dir}" ]; then
        _dr_record "memory.dir" "memory" "pass" "memory/ directory exists"
    else
        if [ "${do_fix}" = "true" ]; then
            mkdir -p "${_mem_dir}"
            _dr_record "memory.dir" "memory" "fail" "memory/ directory was missing -- created" "true" "true"
        else
            _dr_record "memory.dir" "memory" "fail" "memory/ directory missing -- run: lstack doctor --fix" "true"
        fi
    fi

    local _log_dir="${CLAUDE_DIR}/logs"
    if [ -d "${_log_dir}" ]; then
        _dr_record "memory.log_dir" "memory" "pass" "logs/ directory exists"
    else
        if [ "${do_fix}" = "true" ]; then
            mkdir -p "${_log_dir}"
            _dr_record "memory.log_dir" "memory" "fail" "logs/ directory was missing -- created" "true" "true"
        else
            _dr_record "memory.log_dir" "memory" "fail" "logs/ directory missing -- run: lstack doctor --fix" "true"
        fi
    fi

    local _db="${CLAUDE_DIR}/memory/lstack.db"
    if [ -f "${_db}" ]; then
        if [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
            local _db_stats
            _db_stats="$(run_python "${DB_PY}" stats 2>/dev/null | grep -i 'observation' | head -1 || true)"
            if [ -n "${_db_stats}" ]; then
                _dr_record "memory.db" "memory" "pass" "DB accessible: ${_db_stats}"
            else
                _dr_record "memory.db" "memory" "pass" "DB exists at ~/.claude/memory/lstack.db"
            fi
        else
            _dr_record "memory.db" "memory" "pass" "DB exists (Python needed for stats)"
        fi
    else
        if [ "${do_fix}" = "true" ] && [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
            run_python "${DB_PY}" init >/dev/null 2>&1 || true
            _dr_record "memory.db" "memory" "fail" "DB was missing -- initialized" "true" "true"
        else
            _dr_record "memory.db" "memory" "fail" \
                "DB not initialized -- run: lstack memory stats (or lstack doctor --fix)" "true"
        fi
    fi

    # --- Legacy checks (kept from original doctor) ---
    if [ -f "${CLAUDE_DIR}/CLAUDE.md" ]; then
        local _lines
        _lines="$(wc -l < "${CLAUDE_DIR}/CLAUDE.md" | tr -d ' ')"
        if [ "${_lines}" -le 80 ]; then
            _dr_record "config.claude_md" "config" "pass" "CLAUDE.md present (${_lines} lines)"
        else
            _dr_record "config.claude_md" "config" "warn" \
                "CLAUDE.md is ${_lines} lines (over 80) -- edit and trim: \$EDITOR ~/.claude/CLAUDE.md"
        fi
    else
        _dr_record "config.claude_md" "config" "fail" "CLAUDE.md missing"
    fi

    if [ -d "${CLAUDE_DIR}/.git" ] && git -C "${CLAUDE_DIR}" remote get-url origin >/dev/null 2>&1; then
        local _remote
        _remote="$(git -C "${CLAUDE_DIR}" remote get-url origin 2>/dev/null)"
        _dr_record "config.git_remote" "config" "pass" "git remote: ${_remote}"
    else
        _dr_record "config.git_remote" "config" "warn" "No git remote -- upgrade disabled"
    fi

    if [ -f "${CLAUDE_DIR}/settings.json" ] && grep -q 'context7' "${CLAUDE_DIR}/settings.json" 2>/dev/null; then
        _dr_record "config.mcp_context7" "config" "pass" "Context7 MCP configured"
    else
        _dr_record "config.mcp_context7" "config" "warn" "Context7 MCP not in settings.json -- run: lstack settings"
    fi

    local _sl_sh="${CLAUDE_DIR}/scripts/statusline.sh"
    local _sl_py="${CLAUDE_DIR}/scripts/statusline.py"
    if ( [ -f "${_sl_sh}" ] && [ -x "${_sl_sh}" ] ) || [ -f "${_sl_py}" ]; then
        _dr_record "config.statusline" "config" "pass" "statusline script present"
    else
        if [ "${do_fix}" = "true" ] && [ -f "${_sl_sh}" ]; then
            chmod +x "${_sl_sh}" 2>/dev/null || true
            _dr_record "config.statusline" "config" "fail" "statusline not executable -- fixed" "true" "true"
        else
            _dr_record "config.statusline" "config" "fail" \
                "statusline script not executable -- run: chmod +x ~/.claude/scripts/statusline.sh" "true"
        fi
    fi

    # --- Deep checks ---
    if [ "${do_deep}" = "true" ]; then
        for _hf in "${CLAUDE_DIR}/hooks/"*.sh; do
            [ -f "${_hf}" ] || continue
            local _bn
            _bn="$(basename "${_hf}")"
            if bash -n "${_hf}" 2>/dev/null; then
                _dr_record "deep.hook_syntax.${_bn}" "deep" "pass" "bash -n hooks/${_bn}: OK"
            else
                _dr_record "deep.hook_syntax.${_bn}" "deep" "fail" "bash -n hooks/${_bn}: syntax error"
            fi
        done

        if [ -f "${CLAUDE_DIR}/settings.json" ] && [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
            local _settings_content
            _settings_content="$(cat "${CLAUDE_DIR}/settings.json" 2>/dev/null || true)"
            local _home_esc
            _home_esc="$(printf '%s' "${HOME}" | sed 's|/|\\/|g')"
            if printf '%s' "${_settings_content}" | grep -q "${HOME}" 2>/dev/null; then
                _dr_record "deep.settings_hardcoded_paths" "deep" "warn" \
                    "settings.json appears to contain an absolute HOME path -- check for portability"
            else
                _dr_record "deep.settings_hardcoded_paths" "deep" "pass" \
                    "settings.json: no obvious hardcoded home path detected"
            fi
        fi
    fi

    # --- Output ---
    # Pure-bash split: sets _rid _rcat _rsev _rmsg _rfixable _rfixed from "a|b|c|d|e|f"
    _dr_split() {
        local _s="$1"
        _rid="${_s%%|*}";      _s="${_s#*|}"
        _rcat="${_s%%|*}";     _s="${_s#*|}"
        _rsev="${_s%%|*}";     _s="${_s#*|}"
        _rmsg="${_s%%|*}";     _s="${_s#*|}"
        _rfixable="${_s%%|*}"; _s="${_s#*|}"
        _rfixed="${_s}"
    }

    if [ "${do_json}" = "true" ]; then
        if [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
            # Pass header line then result records via stdin; single-quoted Python
            # avoids bash variable expansion and the true/false Python NameError.
            {
                printf '%s|%s|%s|%s\n' "${_overall}" "${_n_pass}" "${_n_warn}" "${_n_fail}"
                if [ "${#_results[@]}" -gt 0 ]; then
                    for _r in "${_results[@]}"; do printf '%s\n' "${_r}"; done
                fi
            } | run_python -c '
import json, sys
lines = sys.stdin.read().splitlines()
header = lines[0].split("|") if lines else ["pass", "0", "0", "0"]
overall = header[0]
n_pass, n_warn, n_fail = int(header[1]), int(header[2]), int(header[3])
checks = []
for line in lines[1:]:
    if not line:
        continue
    parts = line.split("|", 5)
    if len(parts) < 6:
        continue
    ci, cc, cs, cm, cf, cfx = parts
    checks.append({"id": ci, "category": cc, "severity": cs, "message": cm,
                   "fixable": cf == "true", "fixed": cfx == "true"})
print(json.dumps({"status": overall, "checks": checks,
                  "summary": {"pass": n_pass, "warn": n_warn, "fail": n_fail}}, indent=2))
'
        else
            printf '{"status":"%s","error":"Python unavailable for full JSON output","summary":{"pass":%d,"warn":%d,"fail":%d}}\n' \
                "${_overall}" "${_n_pass}" "${_n_warn}" "${_n_fail}"
        fi
        return 0
    fi

    # Human output
    printf 'lstack doctor\n\n'
    local _cur_cat="" _rid _rcat _rsev _rmsg _rfixable _rfixed
    if [ "${#_results[@]}" -gt 0 ]; then
        for _r in "${_results[@]}"; do
            _dr_split "${_r}"
            if [ "${_rcat}" != "${_cur_cat}" ]; then
                _cur_cat="${_rcat}"
                printf '\n%s\n' "$(printf '%s' "${_rcat}" | awk '{print toupper(substr($0,1,1)) substr($0,2)}')"
            fi
            case "${_rsev}" in
                pass) printf '  [\033[32mPASS\033[0m] %s\n' "${_rmsg}" ;;
                warn) printf '  [\033[33mWARN\033[0m] %s\n' "${_rmsg}" ;;
                fail)
                    printf '  [\033[31mFAIL\033[0m] %s\n' "${_rmsg}"
                    if [ "${_rfixable}" = "true" ] && [ "${_rfixed}" = "false" ]; then
                        printf '         Fix: lstack doctor --fix\n'
                    fi
                    ;;
            esac
        done
    fi

    printf '\n'
    printf 'Summary: %d passed, %d warnings, %d failed\n' "${_n_pass}" "${_n_warn}" "${_n_fail}"
    if [ "${_n_fail}" -gt 0 ] && [ "${do_fix}" = "false" ]; then
        printf "Run 'lstack doctor --fix' to repair fixable issues.\n"
    elif [ "${_n_fail}" -eq 0 ] && [ "${_n_warn}" -eq 0 ]; then
        printf 'lstack is healthy.\n'
    fi
    [ "${_n_fail}" -gt 0 ] && return 1 || return 0
}

cmd_onboard() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    printf 'Setting up your lstack environment...\n'
    printf '\n'

    # Step A — name/preferences (skip if preferences.md already has content)
    local _prefs="${CLAUDE_DIR}/memory/preferences.md"
    local _has_prefs=false
    if [ -f "${_prefs}" ]; then
        local _pref_content
        _pref_content="$(grep -v '^#' "${_prefs}" | grep -v '^$' | head -1 || true)"
        [ -n "${_pref_content}" ] && _has_prefs=true
    fi

    if [ "${_has_prefs}" = false ]; then
        printf 'What'\''s your name? (used in CLAUDE.md identity) '
        read -r _name
        printf 'Primary coding language(s)? (e.g. TypeScript, Python, Go) '
        read -r _langs
        printf 'Preferred verbosity? [1=minimal 2=normal 3=detailed] '
        read -r _verbosity

        local _verb_label='normal'
        case "${_verbosity}" in
            1) _verb_label='minimal' ;;
            3) _verb_label='detailed' ;;
        esac

        cat > "${_prefs}" <<PREFEOF
# Preferences
# Updated by lstack onboard

Name: ${_name}
Languages: ${_langs}
Verbosity: ${_verb_label}
PREFEOF
        printf 'Preferences saved to ~/.claude/memory/preferences.md\n'
    else
        _name="$(grep '^Name:' "${_prefs}" 2>/dev/null | sed 's/^Name: *//' | head -1 || true)"
        printf 'Preferences already configured (skipping). To reconfigure: edit ~/.claude/memory/preferences.md\n'
    fi

    # Step B — update CLAUDE.md identity line with name
    if [ -n "${_name:-}" ] && [ -f "${CLAUDE_DIR}/CLAUDE.md" ]; then
        if ! grep -q "${_name}" "${CLAUDE_DIR}/CLAUDE.md" 2>/dev/null; then
            # Replace the Owner: line if present, else leave as-is
            if grep -q '^Model:' "${CLAUDE_DIR}/CLAUDE.md" 2>/dev/null; then
                # Insert name line after the Model: line
                local _tmpf
                _tmpf="$(mktemp)"
                awk -v name="${_name}" '
                    /^Model:/ { print; print "Name:  " name; next }
                    { print }
                ' "${CLAUDE_DIR}/CLAUDE.md" > "${_tmpf}"
                mv "${_tmpf}" "${CLAUDE_DIR}/CLAUDE.md"
                printf 'Added your name to CLAUDE.md identity section.\n'
            fi
        fi
    fi

    # Step C — PATH suggestion
    local _bin="${CLAUDE_DIR}/bin"
    case ":${PATH}:" in
        *":${_bin}:"*) ;; # already in PATH
        *)
            printf '\n'
            printf 'Add lstack to your PATH by adding this to your shell config:\n'
            printf '\n'
            local _shell_name
            _shell_name="$(basename "${SHELL:-bash}")"
            case "${_shell_name}" in
                fish)
                    printf '  fish_add_path ~/.claude/bin\n'
                    printf '\n'
                    printf 'Then restart your terminal or run: source ~/.config/fish/config.fish\n'
                    ;;
                *)
                    printf '  export PATH="$HOME/.claude/bin:$PATH"\n'
                    printf '\n'
                    local _rc=".bashrc"
                    [ "${_shell_name}" = "zsh" ] && _rc=".zshrc"
                    printf 'Then restart your terminal or run: source ~/%s\n' "${_rc}"
                    ;;
            esac
            ;;
    esac

    # Step D — Windows-specific check
    case "${OS}" in
        windows)
            printf '\n'
            printf 'Windows detected. Verifying hook paths in settings.json...\n'
            if [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
                run_python "${DB_PY}" init 2>/dev/null || true
                printf 'Python works: %s\n' "$(python_provider_label)"
            fi
            printf 'Hooks use Git Bash paths (C:/Users/...). Verify in: ~/.claude/settings.json\n'
            printf 'If hooks don'\''t fire, run: lstack settings\n'
            ;;
    esac

    # Step F — sync repo (optional)
    printf '\n'
    printf 'Memory sync across devices (optional).\n'
    printf 'Enter a private git repo URL for cross-device sync,\n'
    printf 'or press Enter to skip: '
    read -r _sync_repo
    if [ -n "${_sync_repo}" ]; then
        printf '%s\n' "${_sync_repo}" > "${CLAUDE_DIR}/memory/.sync-repo"
        printf 'Sync repo saved. Run: lstack sync\n'
    fi

    # Step E — summary
    # Save absolute claude path for hook subprocess use (bypasses PATH issues)
    _claude_bin="$(command -v claude 2>/dev/null || true)"
    if [ -n "${_claude_bin}" ]; then
        printf '%s\n' "${_claude_bin}" > "${CLAUDE_DIR}/memory/.claude-bin"
        echo "claude path saved: ${_claude_bin}"
    else
        echo "Warning: claude not found in PATH - run lstack settings from Git Bash"
    fi

    printf '\n'
    printf 'Onboarding complete. Your setup:\n'
    local _skill_count=0
    if ls "${CLAUDE_DIR}/skills/"*.md >/dev/null 2>&1; then
        _skill_count="$(ls "${CLAUDE_DIR}/skills/"*.md | wc -l | tr -d ' ')"
    fi
    local _hook_count=0
    if ls "${CLAUDE_DIR}/hooks/"*.sh >/dev/null 2>&1; then
        _hook_count="$(ls "${CLAUDE_DIR}/hooks/"*.sh | wc -l | tr -d ' ')"
    fi
    printf '  Skills:  %s skills available\n' "${_skill_count}"
    printf '  Hooks:   %s hooks configured\n' "${_hook_count}"
    local _mem_line='initialized'
    if [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
        _mem_line="$(run_python "${DB_PY}" stats 2>/dev/null | grep -i 'observation' | head -1 || echo 'initialized')"
    fi
    printf '  Memory:  %s\n' "${_mem_line}"
    printf '\n'
    printf 'Start a project: cd your-project && lstack init\n'
}

cmd_forget() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    local query="$*"
    if [ -z "${query}" ]; then
        echo "Usage: lstack forget [search terms]"
        echo "Searches and deletes matching observations from persistent memory."
        exit 1
    fi

    echo "Searching for: ${query}"
    results="$(run_python "${DB_PY}" search "${query}" --limit 10 2>/dev/null)"
    count="$(printf '%s' "${results}" | run_python -c "
import sys,json
try: print(len(json.load(sys.stdin)))
except: print(0)
" 2>/dev/null || echo 0)"

    if [ "${count}" -eq 0 ]; then
        echo "No observations matched '${query}'"
        exit 0
    fi

    echo ""
    echo "Will delete ${count} observation(s):"
    printf '%s' "${results}" | run_python -c "
import sys,json
try:
    for i,it in enumerate(json.load(sys.stdin),1):
        print(f'  [{i}] {it[\"content\"][:80]}')
except: pass
"
    echo ""
    printf "Delete these? [y/N] "
    read -r confirm
    if [ "${confirm}" != "y" ] && [ "${confirm}" != "Y" ]; then
        echo "Cancelled."
        exit 0
    fi

    result="$(run_python "${DB_PY}" forget "${query}" 2>/dev/null)"
    deleted="$(printf '%s' "${result}" | run_python -c "
import sys,json
try: print(json.load(sys.stdin).get('deleted',0))
except: print(0)
")"
    echo "Deleted ${deleted} observation(s)."
}

cmd_edit() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    local query="$*"
    if [ -z "${query}" ]; then
        echo "Usage: lstack edit [search terms]"
        echo "Searches for matching observations, then prompts you to edit one."
        exit 1
    fi

    results="$(run_python "${DB_PY}" search "${query}" --limit 10 2>/dev/null)"
    count="$(printf '%s' "${results}" | run_python -c "
import sys,json
try: print(len(json.load(sys.stdin)))
except: print(0)
" 2>/dev/null || echo 0)"

    if [ "${count}" -eq 0 ]; then
        echo "No observations matched '${query}'"
        exit 0
    fi

    echo "Matching observations:"
    printf '%s' "${results}" | run_python -c "
import sys,json
try:
    for i,it in enumerate(json.load(sys.stdin),1):
        oid=it.get('id','?')
        date=(it.get('created_at',''))[:10]
        scope='global' if it.get('project')=='global' else 'project'
        tags=it.get('tags','')
        print(f'  [{i}] id={oid}  {date}  [{scope}]  {it[\"content\"][:70]}')
        if tags:
            print(f'       tags: {tags}')
except Exception as e:
    print(f'Error: {e}')
"

    echo ""
    printf "Observation ID to edit: "
    read -r edit_id
    if [ -z "${edit_id}" ]; then
        echo "Cancelled."
        exit 0
    fi

    printf "Field to edit [content/tags/scope]: "
    read -r field

    case "${field}" in
        content)
            printf "New content: "
            read -r new_val
            result="$(run_python "${DB_PY}" edit "${edit_id}" --content "${new_val}" 2>/dev/null)"
            ;;
        tags)
            printf "New tags (comma-separated): "
            read -r new_val
            result="$(run_python "${DB_PY}" edit "${edit_id}" --tags "${new_val}" 2>/dev/null)"
            ;;
        scope)
            printf "New scope [project/global]: "
            read -r new_scope
            if [ "${new_scope}" = "global" ]; then
                new_project="global"
            else
                new_project="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
            fi
            result="$(run_python "${DB_PY}" edit "${edit_id}" --project "${new_project}" 2>/dev/null)"
            ;;
        *)
            echo "Unknown field '${field}'. Use: content, tags, or scope"
            exit 1
            ;;
    esac

    err="$(printf '%s' "${result}" | run_python -c "
import sys,json
try: print(json.load(sys.stdin).get('error',''))
except: print('')
" 2>/dev/null)"

    if [ -n "${err}" ]; then
        echo "Error: ${err}"
        exit 1
    fi

    echo "Updated observation ${edit_id}."
}

cmd_analytics() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    run_python "${CLAUDE_DIR}/scripts/db.py" analytics
}

cmd_learn() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    local subcmd="${1:-help}"
    shift 2>/dev/null || true

    case "${subcmd}" in
        add)                  run_python "${DB_PY}" learn-add "$@" ;;
        search)               run_python "${DB_PY}" learn-search "$@" ;;
        list)                 run_python "${DB_PY}" learn-list "$@" ;;
        show)                 run_python "${DB_PY}" learn-show "$@" ;;
        forget)               run_python "${DB_PY}" learn-forget "$@" ;;
        promote)              run_python "${DB_PY}" learn-promote "$@" ;;
        demote)               run_python "${DB_PY}" learn-demote "$@" ;;
        stats)                run_python "${DB_PY}" learn-stats "$@" ;;
        prune)                run_python "${DB_PY}" learn-prune "$@" ;;
        embed-all)            run_python "${DB_PY}" learn-embed-all "$@" ;;
        export)               run_python "${DB_PY}" learn-export "$@" ;;
        import)               run_python "${DB_PY}" learn-import "$@" ;;
        migrate-observations) run_python "${DB_PY}" learn-migrate-observations "$@" ;;
        config)               run_python "${DB_PY}" learn-config "$@" ;;
        help|--help|-h|"")
            cat <<EOF
Usage: lstack learn <command> [options]

Commands:
  add                  Add a structured learning
  search QUERY         Search structured learnings
  list                 List structured learnings
  show ID              Show one learning
  forget               Delete by --id, --key/--type, or query
  promote --id ID      Mark trusted after explicit user request
  demote --id ID       Mark untrusted
  stats                Show learning analytics
  prune                Delete matching learnings with --dry-run or --apply
  embed-all            Backfill semantic embeddings for learnings
  export               Export JSONL
  import FILE          Import JSONL with validation
  migrate-observations Convert selected legacy observations on request
  config show|set      Show or update learning config
EOF
            ;;
        *)
            echo "Unknown learn subcommand: ${subcmd}"
            echo "Run: lstack learn help"
            exit 1
            ;;
    esac
}

cmd_sync() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    local sync_repo_file="${CLAUDE_DIR}/memory/.sync-repo"
    local sync_dir="${CLAUDE_DIR}/memory/sync"

    if [ ! -f "${sync_repo_file}" ]; then
        echo "No sync repo configured."
        echo "Run 'lstack onboard' to set one up, or:"
        echo "  echo 'git@github.com:you/lstack-sync.git' > ~/.claude/memory/.sync-repo"
        exit 1
    fi

    local sync_repo
    sync_repo="$(cat "${sync_repo_file}")"

    if [ ! -d "${sync_dir}/.git" ]; then
        echo "Cloning sync repo..."
        git clone "${sync_repo}" "${sync_dir}" || {
            echo "Clone failed. Check your repo URL and SSH keys."
            exit 1
        }
    fi

    echo "Pulling from sync repo..."
    git -C "${sync_dir}" pull --ff-only origin main 2>/dev/null || \
    git -C "${sync_dir}" pull --ff-only origin master 2>/dev/null || true

    if [ -f "${sync_dir}/observations.json" ]; then
        echo "Importing observations from sync..."
        run_python "${DB_PY}" import "${sync_dir}/observations.json"
    fi

    echo "Exporting current observations..."
    run_python "${DB_PY}" export > "${sync_dir}/observations.json"

    git -C "${sync_dir}" add observations.json
    if ! git -C "${sync_dir}" diff --cached --quiet; then
        git -C "${sync_dir}" commit -m "lstack sync $(date -u '+%Y-%m-%dT%H:%M:%SZ')"
        git -C "${sync_dir}" push origin HEAD
        echo "Sync complete."
    else
        echo "Nothing new to push."
    fi
}

cmd_mcp() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    echo "Starting lstack MCP server (stdio)..."
    echo "To register with Claude Code:"
    echo "  claude mcp add lstack -- $(python_provider_label) ${CLAUDE_DIR}/scripts/mcp_server.py"
    run_python "${CLAUDE_DIR}/scripts/mcp_server.py"
}

cmd_health() {
    source "${CLAUDE_DIR}/scripts/os.sh"
    if [ -f "${CLAUDE_DIR}/scripts/runtime.sh" ]; then
        # shellcheck source=scripts/runtime.sh
        source "${CLAUDE_DIR}/scripts/runtime.sh"
    fi

    local do_json=false do_save=true do_history=false do_compare=false
    local do_configure=false do_detect=false timeout_per_tool=120
    for _a in "$@"; do
        case "${_a}" in
            --json)      do_json=true ;;
            --save)      do_save=true ;;
            --no-save)   do_save=false ;;
            --history)   do_history=true ;;
            --compare)   do_compare=true ;;
            --configure) do_configure=true ;;
            --detect)    do_detect=true ;;
            --fast)      timeout_per_tool=30 ;;
            --full)      timeout_per_tool=300 ;;
        esac
    done

    # History display
    if [ "${do_history}" = "true" ]; then
        local _hf="${CLAUDE_DIR}/memory/health-history.jsonl"
        if [ ! -f "${_hf}" ]; then
            printf 'No health history found.\n'
            return 0
        fi
        printf 'Health history\n\n'
        printf '%-20s %-6s %-20s\n' "Date" "Score" "Branch"
        printf '%-20s %-6s %-20s\n' "----" "-----" "------"
        if [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
            run_python -c "
import json, sys
lines = open('${_hf}').readlines()
for line in reversed(lines[-10:]):
    try:
        d = json.loads(line)
        ts = d.get('ts','?')[:16].replace('T',' ')
        score = d.get('score','?')
        branch = d.get('branch','-')
        print(f'{ts:<20} {score:<6} {branch}')
    except: pass
" 2>/dev/null || tail -10 "${_hf}"
        else
            tail -10 "${_hf}"
        fi
        return 0
    fi

    # Find project root
    local _proj_root
    _proj_root="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
    local _proj_name
    _proj_name="$(basename "${_proj_root}")"
    local _branch=""
    _branch="$(git -C "${_proj_root}" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "-")"
    local _commit=""
    _commit="$(git -C "${_proj_root}" rev-parse --short HEAD 2>/dev/null || echo "")"
    local _ts
    _ts="$(date -u '+%Y-%m-%dT%H:%M:%SZ' 2>/dev/null || echo "")"

    # Parse Health Stack or Build & Test section from .claude/CLAUDE.md
    # Pass path via sys.argv so MSYS2 converts POSIX path to Windows for native Python.
    local _claude_md="${_proj_root}/.claude/CLAUDE.md"
    declare -A _hs_commands
    if [ -f "${_claude_md}" ] && [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
        local _parsed
        _parsed="$(run_python -c '
import re, sys
try:
    content = open(sys.argv[1]).read()
    m = re.search(r"##\s+Health Stack\s*\n(.*?)(?=\n##|\Z)", content, re.DOTALL)
    if not m:
        m = re.search(r"##\s+Build\s*&\s*Test\s*\n(.*?)(?=\n##|\Z)", content, re.DOTALL)
    if m:
        for line in m.group(1).splitlines():
            line = line.strip()
            if ":" in line and not line.startswith("#"):
                k, _, v = line.partition(":")
                k = k.strip(); v = v.strip()
                if k and v:
                    print(k + "=" + v)
except Exception:
    pass
' "${_claude_md}" 2>/dev/null || true)"
        while IFS='=' read -r _k _v; do
            [ -n "${_k}" ] && [ -n "${_v}" ] && _hs_commands["${_k}"]="${_v}"
        done <<< "${_parsed}"
    fi

    # Auto-detect tools if no Health Stack config
    _detect_health_tools() {
        # Shell check - always available if bash exists
        local _sh_scripts=""
        for _d in hooks scripts; do
            [ -d "${_proj_root}/${_d}" ] && ls "${_proj_root}/${_d}"/*.sh >/dev/null 2>&1 && \
                _sh_scripts="${_sh_scripts} ${_proj_root}/${_d}/*.sh"
        done
        if [ -n "${_sh_scripts}" ]; then
            if command -v shellcheck >/dev/null 2>&1; then
                echo "shell=shellcheck${_sh_scripts}"
            else
                echo "shell=bash -n ${_sh_scripts# }"
            fi
        fi

        # Node -- pass path via sys.argv so MSYS2 converts POSIX to Windows for Python
        if [ -f "${_proj_root}/package.json" ]; then
            local _pm="npm"
            [ -f "${_proj_root}/pnpm-lock.yaml" ] && _pm="pnpm"
            { [ -f "${_proj_root}/bun.lock" ] || [ -f "${_proj_root}/bun.lockb" ]; } && _pm="bun"
            [ -f "${_proj_root}/yarn.lock" ] && _pm="yarn"
            if [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
                run_python -c '
import json, sys
try:
    pkg_path = sys.argv[1]
    pm = sys.argv[2]
    scripts = json.load(open(pkg_path)).get("scripts", {})
    for k, cat in [("test","tests"),("typecheck","typecheck"),("lint","lint"),
                   ("build","build"),("format:check","format"),("check","lint")]:
        if k in scripts:
            print(cat + "=" + (pm + " test" if k == "test" else pm + " run " + k))
except Exception:
    pass
' "${_proj_root}/package.json" "${_pm}" 2>/dev/null || true
            fi
        fi

        # Python
        if [ -f "${_proj_root}/pyproject.toml" ] || [ -f "${_proj_root}/requirements.txt" ] || [ -f "${_proj_root}/setup.py" ]; then
            command -v pytest >/dev/null 2>&1 && echo "tests=pytest"
            command -v ruff  >/dev/null 2>&1 && echo "lint=ruff check ."
            command -v mypy  >/dev/null 2>&1 && echo "typecheck=mypy ."
        fi

        # Go
        if [ -f "${_proj_root}/go.mod" ]; then
            command -v go >/dev/null 2>&1 && echo "tests=go test ./..." && echo "build=go build ./..."
        fi

        # Rust
        if [ -f "${_proj_root}/Cargo.toml" ]; then
            command -v cargo >/dev/null 2>&1 && echo "tests=cargo test" && echo "build=cargo build" && echo "lint=cargo clippy"
        fi
    }

    # Merge: Health Stack takes precedence over auto-detect
    declare -A _tools
    while IFS='=' read -r _k _v; do
        [ -n "${_k}" ] && [ -n "${_v}" ] && _tools["${_k}"]="${_v}"
    done <<< "$(_detect_health_tools)"
    for _k in "${!_hs_commands[@]}"; do
        _tools["${_k}"]="${_hs_commands[${_k}]}"
    done

    # Detect-only mode
    if [ "${do_detect}" = "true" ] || [ "${do_configure}" = "true" ]; then
        printf 'Detected health tools for: %s\n\n' "${_proj_name}"
        for _k in "${!_tools[@]}"; do
            printf '  %-14s %s\n' "${_k}:" "${_tools[${_k}]}"
        done
        if [ "${do_configure}" = "true" ] && [ -t 0 ]; then
            printf '\nWrite Health Stack section to %s? [y/N] ' "${_claude_md}"
            read -r _ans
            if [ "${_ans}" = "y" ] || [ "${_ans}" = "Y" ]; then
                mkdir -p "$(dirname "${_claude_md}")"
                if [ -f "${_claude_md}" ] && grep -q '## Health Stack' "${_claude_md}" 2>/dev/null; then
                    printf 'Health Stack section already exists in %s\n' "${_claude_md}"
                else
                    local _ts_bak
                    _ts_bak="$(date -u '+%Y%m%d%H%M%S')"
                    [ -f "${_claude_md}" ] && cp "${_claude_md}" "${_claude_md}.bak.${_ts_bak}"
                    {
                        printf '\n## Health Stack\n'
                        for _k in "${!_tools[@]}"; do
                            printf '%s: %s\n' "${_k}" "${_tools[${_k}]}"
                        done
                    } >> "${_claude_md}"
                    printf 'Health Stack section added to %s\n' "${_claude_md}"
                fi
            fi
        fi
        return 0
    fi

    # Default weights
    declare -A _weights
    _weights=(["typecheck"]=22 ["tests"]=28 ["lint"]=18 ["build"]=12 ["format"]=8 ["deadcode"]=6 ["shell"]=6)

    # Run tools and collect results
    declare -A _scores _statuses _commands _exit_codes _durations _summaries

    _run_health_tool() {
        local _name="$1" _cmd="$2" _timeout="$3"
        local _start _end _output _rc

        _start="$(date +%s 2>/dev/null || echo 0)"
        if command -v timeout >/dev/null 2>&1; then
            _output="$(timeout "${_timeout}" bash -c "cd '${_proj_root}' && ${_cmd}" 2>&1)" || true
            _rc=$?
            # timeout exits 124 on timeout
        elif [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
            _output="$(run_python -c "
import subprocess, sys
try:
    r = subprocess.run('${_cmd}', shell=True, capture_output=True, text=True, timeout=${_timeout}, cwd='${_proj_root}')
    sys.stdout.write(r.stdout + r.stderr)
    sys.exit(r.returncode)
except subprocess.TimeoutExpired:
    sys.stdout.write('TIMEOUT')
    sys.exit(124)
" 2>&1)" || true
            _rc=$?
        else
            _output="$(bash -c "cd '${_proj_root}' && ${_cmd}" 2>&1)" || true
            _rc=$?
        fi
        _end="$(date +%s 2>/dev/null || echo 0)"
        _output="$(printf '%s' "${_output}" | tail -80)"

        local _score
        if [ "${_rc}" -eq 0 ]; then
            _score=10
        elif [ "${_rc}" -eq 124 ]; then
            _score=0
        else
            local _err_count
            _err_count="$(printf '%s' "${_output}" | grep -ciE 'error|fail|FAIL' 2>/dev/null || echo 0)"
            if [ "${_err_count}" -le 3 ]; then _score=7
            elif [ "${_err_count}" -le 10 ]; then _score=4
            else _score=0; fi
        fi

        local _dur=$(( _end - _start ))
        local _summary
        if [ "${_rc}" -eq 124 ]; then
            _summary="TIMEOUT after ${_timeout}s"
        elif [ "${_rc}" -eq 0 ]; then
            _summary="ok"
        else
            local _ec
            _ec="$(printf '%s' "${_output}" | grep -ciE 'error|fail|FAIL' 2>/dev/null || echo "?")"
            _summary="${_ec} error(s)"
        fi

        _scores["${_name}"]=${_score}
        _statuses["${_name}"]="${_rc}"
        _commands["${_name}"]="${_cmd}"
        _exit_codes["${_name}"]=${_rc}
        _durations["${_name}"]=${_dur}
        _summaries["${_name}"]="${_summary}"
    }

    _score_label() {
        local _s="$1"
        if   [ "${_s}" -ge 10 ]; then echo "CLEAN"
        elif [ "${_s}" -ge 7 ];  then echo "WARNING"
        elif [ "${_s}" -ge 4 ];  then echo "NEEDS WORK"
        else echo "CRITICAL"; fi
    }

    for _cat in "${!_tools[@]}"; do
        _run_health_tool "${_cat}" "${_tools[${_cat}]}" "${timeout_per_tool}"
    done

    # Compute composite score
    local _total_score=0 _total_weight=0
    local _recommendations=()

    for _cat in "${!_scores[@]}"; do
        local _w="${_weights[${_cat}]:-5}"
        _total_score=$(( _total_score + _scores["${_cat}"] * _w ))
        _total_weight=$(( _total_weight + _w ))
        if [ "${_scores[${_cat}]}" -lt 10 ]; then
            case "${_scores[${_cat}]}" in
                7|8|9) _recommendations+=("Fix ${_exit_codes[${_cat}]} issue(s) in ${_cat} (${_tools[${_cat}]}).") ;;
                0|1|2|3|4|5|6) _recommendations+=("Critical: fix ${_cat} failures (${_tools[${_cat}]}).") ;;
            esac
        fi
    done

    if [ ${#_tools[@]} -eq 0 ]; then
        _recommendations+=("No health tools detected. Add a '## Health Stack' section to .claude/CLAUDE.md.")
    fi

    local _composite="0"
    if [ "${_total_weight}" -gt 0 ] && [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
        _composite="$(run_python -c "print(f'{${_total_score}/${_total_weight}:.1f}')" 2>/dev/null || echo "0")"
    fi

    # JSON output
    if [ "${do_json}" = "true" ]; then
        if [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
            run_python -c "
import json, sys
cats = {}
$(for _cat in "${!_scores[@]}"; do
    echo "cats['${_cat}'] = {'score': ${_scores[${_cat}]}, 'status': '$(_score_label "${_scores[${_cat}]}")', 'command': '${_commands[${_cat}]}', 'exit_code': ${_exit_codes[${_cat}]}, 'duration_s': ${_durations[${_cat}]}, 'summary': '${_summaries[${_cat}]}'}"
done)
recs = [$(for _r in "${_recommendations[@]:-}"; do printf "'%s'," "${_r}"; done)]
print(json.dumps({'project':'${_proj_name}','branch':'${_branch}','commit_sha':'${_commit}','score':${_composite},'ts':'${_ts}','categories':cats,'recommendations':recs}, indent=2))
" 2>/dev/null || printf '{"error":"JSON generation failed"}\n'
        else
            printf '{"project":"%s","branch":"%s","score":%s,"error":"Python unavailable for full JSON"}\n' \
                "${_proj_name}" "${_branch}" "${_composite}"
        fi
        # Fall through to save
        if [ "${do_save}" = "false" ]; then return 0; fi
    fi

    # Human output
    if [ "${do_json}" = "false" ]; then
        printf 'lstack health\n\n'
        printf 'Project: %s\n' "${_proj_name}"
        printf 'Branch:  %s\n' "${_branch}"
        printf 'Date:    %s\n\n' "$(date '+%Y-%m-%d' 2>/dev/null || echo '?')"

        if [ ${#_tools[@]} -eq 0 ]; then
            printf 'No health tools detected in this project.\n'
            printf 'Add a "## Health Stack" section to .claude/CLAUDE.md, or run:\n'
            printf '  lstack health --configure\n\n'
        else
            printf '%-12s %-26s %-6s %-12s %-9s %s\n' \
                "Category" "Tool" "Score" "Status" "Duration" "Details"
            printf '%-12s %-26s %-6s %-12s %-9s %s\n' \
                "--------" "----" "-----" "------" "--------" "-------"
            for _cat in "${!_scores[@]}"; do
                local _lbl
                _lbl="$(_score_label "${_scores[${_cat}]}")"
                local _cmd_short="${_commands[${_cat}]}"
                [ ${#_cmd_short} -gt 24 ] && _cmd_short="${_cmd_short:0:21}..."
                printf '%-12s %-26s %2d/10  %-12s %ds         %s\n' \
                    "${_cat}" "${_cmd_short}" "${_scores[${_cat}]}" "${_lbl}" \
                    "${_durations[${_cat}]}" "${_summaries[${_cat}]}"
            done
        fi

        printf '\nComposite score: %s / 10\n' "${_composite}"

        if [ ${#_recommendations[@]} -gt 0 ]; then
            printf '\nTop recommendations:\n'
            local _ri=1
            for _rec in "${_recommendations[@]}"; do
                printf '  %d. %s\n' "${_ri}" "${_rec}"
                _ri=$(( _ri + 1 ))
            done
        fi
    fi

    # Compare mode
    if [ "${do_compare}" = "true" ] && [ -f "${CLAUDE_DIR}/memory/health-history.jsonl" ] && \
       [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
        printf '\nComparison with previous:\n'
        run_python -c "
import json
lines = [l for l in open('${CLAUDE_DIR}/memory/health-history.jsonl') if '${_proj_name}' in l]
if lines:
    prev = json.loads(lines[-1])
    curr = ${_composite}
    prev_score = prev.get('score', 0)
    diff = curr - prev_score
    sign = '+' if diff >= 0 else ''
    print(f'  Current:  {curr}  ({\"${_branch}\"})')
    print(f'  Previous: {prev_score}  ({prev.get(\"branch\",\"?\")})')
    print(f'  Change:   {sign}{diff:.1f}  ({\"improving\" if diff > 0 else \"declining\" if diff < 0 else \"stable\"})')
else:
    print('  No previous history for this project.')
" 2>/dev/null || true
    fi

    # Save history
    if [ "${do_save}" = "true" ] && [ "${PYTHON_AVAILABLE:-false}" = "true" ]; then
        local _hf="${CLAUDE_DIR}/memory/health-history.jsonl"
        mkdir -p "$(dirname "${_hf}")"
        run_python -c "
import json
rec = {'ts':'${_ts}','project':'${_proj_name}','branch':'${_branch}','commit_sha':'${_commit}',
       'score':${_composite},
       'category_scores':{ $(for _cat in "${!_scores[@]}"; do printf "'%s':%d," "${_cat}" "${_scores[${_cat}]}"; done) },
       'duration_s':$(( $(date +%s 2>/dev/null || echo 0) - $(date +%s 2>/dev/null || echo 0) ))}
with open('${_hf}', 'a') as f:
    f.write(json.dumps(rec) + '\n')
" 2>/dev/null || true
    fi
}

cmd_settings() {
    out="${CLAUDE_DIR}/settings.json"
    echo "Regenerating ${out} for current OS..."
    bash "${CLAUDE_DIR}/scripts/gen-settings.sh" > "${out}"
    # Save absolute claude path for hook subprocess use (bypasses PATH issues)
    _claude_bin="$(command -v claude 2>/dev/null || true)"
    if [ -n "${_claude_bin}" ]; then
        printf '%s\n' "${_claude_bin}" > "${CLAUDE_DIR}/memory/.claude-bin"
        echo "claude path saved: ${_claude_bin}"
    else
        echo "Warning: claude not found in PATH - run lstack settings from Git Bash"
    fi
    echo "Done. Validating JSON..."
    source "${CLAUDE_DIR}/scripts/os.sh"
    run_python -m json.tool "${out}" > /dev/null && echo "settings.json is valid." || echo "Warning: JSON validation failed."
}

# Main dispatch
cmd="${1:-help}"
shift 2>/dev/null || true

case "${cmd}" in
    init)      cmd_init "$@" ;;
    settings)  cmd_settings "$@" ;;
    runtime)   cmd_runtime "$@" ;;
    doctor)    cmd_doctor "$@" ;;
    health)    cmd_health "$@" ;;
    onboard)   cmd_onboard "$@" ;;
    memory)    cmd_memory "$@" ;;
    search)    cmd_search "$@" ;;
    logs)      cmd_logs "$@" ;;
    status)    cmd_status "$@" ;;
    freeze)    cmd_freeze "$@" ;;
    unfreeze)  cmd_unfreeze "$@" ;;
    safety)    cmd_safety "$@" ;;
    guard)     cmd_guard "$@" ;;
    clean)     cmd_clean "$@" ;;
    dashboard) cmd_dashboard "$@" ;;
    upgrade)   cmd_upgrade "$@" ;;
    publish)   cmd_publish "$@" ;;
    forget)    cmd_forget "$@" ;;
    edit)      cmd_edit "$@" ;;
    analytics) cmd_analytics "$@" ;;
    brain)     cmd_brain "$@" ;;
    learn)     cmd_learn "$@" ;;
    mcp)       cmd_mcp "$@" ;;
    sync)      cmd_sync "$@" ;;
    help|--help|-h) usage ;;
    *)
        echo "Unknown command: ${cmd}"
        echo ""
        usage
        exit 1
        ;;
esac
